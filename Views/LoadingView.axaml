<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             x:Class="d2c_launcher.Views.LoadingView"
             x:DataType="vm:LoadingViewModel"
             Classes="InitScreen">

    <StackPanel Classes="InitScreenContent">

        <TextBlock Classes="InitScreenTitle" Text="Dotaclassic"/>

        <ProgressBar IsIndeterminate="True"
                     Width="200" Height="4"
                     CornerRadius="0"
                     Foreground="#3a90d6"
                     Background="#2a2a2a"/>

        <TextBlock Text="Подключение к Steam..."
                   FontSize="{DynamicResource FontSizeMD}" HorizontalAlignment="Center"
                   Foreground="#888888"/>

    </StackPanel>

</UserControl>

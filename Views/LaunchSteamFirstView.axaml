<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             x:Class="d2c_launcher.Views.LaunchSteamFirstView"
             x:DataType="vm:LaunchSteamFirstViewModel">

    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0c0c0c" Offset="0"/>
            <GradientStop Color="#141820" Offset="0.35"/>
            <GradientStop Color="#1c2024" Offset="0.5"/>
            <GradientStop Color="#141820" Offset="0.65"/>
            <GradientStop Color="#0c0c0c" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                Spacing="16" MaxWidth="420" Margin="24,0">

        <!-- Steam icon -->
        <Border Width="64" Height="64"
                Background="#1a2030"
                BorderBrush="#2d3842" BorderThickness="1"
                HorizontalAlignment="Center"
                Opacity="0.8">
            <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                  Width="36" Height="36"
                  Stretch="Uniform"
                  Fill="#6c9bcf"
                  Data="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"/>
        </Border>

        <TextBlock Text="Dotaclassic"
                   FontFamily="{StaticResource TrajanPro3}"
                   FontSize="{DynamicResource FontSize3XL}" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="#D9D9D9"
                   LetterSpacing="2"/>

        <TextBlock FontSize="{DynamicResource FontSizeLG}" HorizontalAlignment="Center"
                   Foreground="#AAAAAA"
                   TextWrapping="Wrap"
                   TextAlignment="Center">
            <TextBlock.Inlines>
                <Run Text="Для запуска лаунчера необходим&#10;запущенный и авторизованный "/>
                <Run Text="Steam" Foreground="#6c9bcf" FontWeight="SemiBold"/>
            </TextBlock.Inlines>
        </TextBlock>

        <Rectangle Height="1" Fill="#1e1e1e" HorizontalAlignment="Stretch"/>

        <TextBlock Text="Убедитесь, что Steam запущен и вы вошли в аккаунт. Окно обновится автоматически."
                   FontSize="{DynamicResource FontSizeBase}" HorizontalAlignment="Center"
                   Foreground="#888888"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>

        <!-- Open Steam button -->
        <Button HorizontalAlignment="Stretch"
                Padding="32,10" CornerRadius="0"
                FontSize="{DynamicResource FontSizeXL}" FontWeight="SemiBold"
                Foreground="White" BorderThickness="0"
                Margin="0,4,0,0"
                Command="{Binding OpenSteamCommand}">
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#3a90d6" Offset="0"/>
                    <GradientStop Color="#1a5aaa" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
            <TextBlock Text="Открыть Steam"
                       FontSize="{DynamicResource FontSizeXL}" FontWeight="SemiBold" Foreground="White"
                       HorizontalAlignment="Center"/>
        </Button>

        <!-- Try again link -->
        <Button HorizontalAlignment="Center"
                Padding="0,4" CornerRadius="0"
                Background="Transparent" BorderThickness="0"
                Command="{Binding TryAgainCommand}">
            <TextBlock Text="Попробовать снова"
                       FontSize="{DynamicResource FontSizeMD}" Foreground="#888888"
                       TextDecorations="Underline"/>
        </Button>

    </StackPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:res="clr-namespace:d2c_launcher.Resources"
             x:Class="d2c_launcher.Views.GameDownloadView"
             x:DataType="vm:GameDownloadViewModel"
             Classes="InitScreen">

    <Panel>
        <!-- Main content -->
        <StackPanel Classes="InitScreenContent">

            <TextBlock Classes="InitScreenTitle" Text="Dotaclassic"/>

            <TextBlock Text="{Binding StatusText}"
                       FontSize="{DynamicResource FontSizeLG}" HorizontalAlignment="Center"
                       Foreground="#AAAAAA"/>

            <ProgressBar Value="{Binding ProgressValue}"
                         IsIndeterminate="{Binding IsIndeterminate}"
                         Minimum="0" Maximum="100"
                         Height="6" CornerRadius="0"
                         Foreground="#3a90d6"
                         Background="#2a2a2a">
                <ProgressBar.Styles>
                    <!-- Kill the internal indicator transitions so switching IsIndeterminate
                         doesn't produce a flash from the animation's current position to 0. -->
                    <Style Selector="ProgressBar /template/ Border#PART_Indicator">
                        <Setter Property="Transitions" Value="{x:Null}"/>
                    </Style>
                </ProgressBar.Styles>
            </ProgressBar>

            <TextBlock Text="{Binding CurrentFileText}"
                       IsVisible="{Binding CurrentFileText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       FontSize="{DynamicResource FontSizeBase}" HorizontalAlignment="Center"
                       Foreground="#888888"
                       TextTrimming="CharacterEllipsis"
                       TextAlignment="Center"/>

            <TextBlock Text="{Binding DetailsText}"
                       IsVisible="{Binding DetailsText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       FontSize="{DynamicResource FontSizeBase}" HorizontalAlignment="Center"
                       Foreground="#888888"
                       TextAlignment="Center"/>

            <!-- Error panel -->
            <StackPanel IsVisible="{Binding HasError}" Spacing="12" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ErrorText}"
                           FontSize="{DynamicResource FontSizeMD}" Foreground="#e05555"
                           TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="420"/>
                <Button Command="{Binding RetryCommand}"
                        HorizontalAlignment="Center"
                        Padding="24,7" CornerRadius="0"
                        Background="Transparent"
                        BorderBrush="#e05555" BorderThickness="1"
                        Foreground="#e05555"
                        FontSize="{DynamicResource FontSizeMD}" FontWeight="SemiBold">
                    <TextBlock Text="{x:Static res:Strings.Retry}"
                               FontSize="{DynamicResource FontSizeMD}" FontWeight="SemiBold" Foreground="#e05555"/>
                </Button>
            </StackPanel>

        </StackPanel>

        <!-- Windows Defender exclusion confirmation modal -->
        <Panel IsVisible="{Binding ShowDefenderModal}" ZIndex="200"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
               Background="#90000000">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="28" CornerRadius="0" MinWidth="400" MaxWidth="520"
                    Background="#121315" BorderBrush="#2d3842" BorderThickness="1"
                    BoxShadow="0 12 28 0 #80000000">
                <StackPanel Spacing="20">
                    <TextBlock Text="{x:Static res:Strings.DefenderExclusionTitle}"
                               FontSize="{DynamicResource FontSize2XL}" FontWeight="SemiBold"
                               Foreground="#D9D9D9"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="{DynamicResource FontSizeMD}" LineHeight="20">
                        <Run Text="{x:Static res:Strings.DefenderAddExclusionPrompt}"/>
                        <Run Text="&#10;&#10;"/>
                        <Run Text="{x:Static res:Strings.DefenderExclusionExplanation}"/>
                        <Run Text="&#10;&#10;"/>
                        <Run Text="{x:Static res:Strings.UacNote}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Command="{Binding SkipDefenderCommand}"
                                Content="{x:Static res:Strings.Skip}"
                                Padding="20,8" CornerRadius="0"
                                Background="Transparent"
                                BorderBrush="#444" BorderThickness="1"
                                Foreground="#AAAAAA" FontSize="{DynamicResource FontSizeMD}"/>
                        <Button Classes="PrimaryButton"
                                Command="{Binding AcceptDefenderCommand}"
                                Content="{x:Static res:Strings.AddException}"
                                Padding="20,8" CornerRadius="0"
                                FontSize="{DynamicResource FontSizeMD}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Panel>
    </Panel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:api="using:d2c_launcher.Api"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:l="clr-namespace:d2c_launcher.Util"
             x:Class="d2c_launcher.Views.Components.StreamsPanel"
             x:DataType="vm:StreamsViewModel">

  <Border Classes="Block" ClipToBounds="True">
    <Grid RowDefinitions="Auto,*">

      <!-- Header -->
      <Border Grid.Row="0" Classes="BlockHead">
        <TextBlock Classes="BlockTitle" Text="{l:T 'streams.tabLabel'}"/>
      </Border>

      <!-- Content -->
      <Grid Grid.Row="1">

        <!-- Loading -->
        <TextBlock IsVisible="{Binding IsLoading}"
                   Text="{l:T 'common.loading'}"
                   Foreground="#888888" FontSize="{DynamicResource FontSizeSM}"
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <!-- Empty state -->
        <TextBlock IsVisible="{Binding HasNoStreams}"
                   Text="{l:T 'streams.noStreams'}"
                   Foreground="#888888" FontSize="{DynamicResource FontSizeSM}"
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <!-- Stream list + CTA -->
        <ScrollViewer IsVisible="{Binding !IsLoading}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel>

            <!-- Stream rows -->
            <ItemsControl ItemsSource="{Binding Streams}" IsVisible="{Binding HasAnyStreams}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="api:TwitchStreamDto">
                  <Button Click="OnStreamCardClicked"
                          Tag="{Binding Link}"
                          Background="Transparent" BorderThickness="0"
                          Padding="0" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Cursor="Hand" CornerRadius="0">
                    <Button.Styles>
                      <Style Selector="Button /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                      </Style>
                      <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#0d1520"/>
                      </Style>
                    </Button.Styles>
                    <Grid ColumnDefinitions="Auto,*"
                          Height="110"
                          Margin="0,0,0,0">
                      <!-- Bottom separator -->
                      <Border Grid.ColumnSpan="2"
                              BorderBrush="#1e2a38" BorderThickness="0,0,0,1"
                              VerticalAlignment="Stretch"/>

                      <!-- Thumbnail -->
                      <Border Grid.Column="0"
                              Width="196" Height="110"
                              ClipToBounds="True" Background="#0a0f18">
                        <Image asyncImageLoader:ImageLoader.Source="{Binding Preview}"
                               Stretch="UniformToFill"/>
                      </Border>

                      <!-- Info -->
                      <StackPanel Grid.Column="1"
                                  Margin="16,0,16,0"
                                  Spacing="6"
                                  VerticalAlignment="Center">

                        <!-- Title -->
                        <TextBlock Text="{Binding Title}"
                                   Foreground="#d0d8e0"
                                   FontSize="{DynamicResource FontSizeLG}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2"
                                   TextWrapping="Wrap"/>

                        <!-- Streamer row -->
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

                          <!-- Avatar + name -->
                          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <Border Width="22" Height="22" CornerRadius="11" ClipToBounds="True"
                                    Background="#1a2535">
                              <Image asyncImageLoader:ImageLoader.Source="{Binding User.AvatarSmall}"
                                     Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock Text="{Binding User.Name}"
                                       Foreground="#5a90c0"
                                       FontSize="{DynamicResource FontSizeSM}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                          </StackPanel>

                          <!-- Viewer count -->
                          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5"
                                      VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="#e74c3c" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Viewers}"
                                       Foreground="#8a9aaa" FontSize="{DynamicResource FontSizeSM}"/>
                            <TextBlock Text="{l:T 'streams.viewers'}"
                                       Foreground="#8a9aaa" FontSize="{DynamicResource FontSizeSM}"/>
                          </StackPanel>

                        </Grid>
                      </StackPanel>
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- CTA row -->
            <Button Click="OnCtaClicked"
                    Tag="{Binding PlayerSettingsUrl}"
                    IsVisible="{Binding PlayerSettingsUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="Transparent" BorderThickness="0"
                    Padding="0" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand" CornerRadius="0">
              <Button.Styles>
                <Style Selector="Button /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="Button:pointerover /template/ ContentPresenter">
                  <Setter Property="Background" Value="#0d1118"/>
                </Style>
              </Button.Styles>
              <Border BorderBrush="#1e2a38" BorderThickness="0,0,0,1" Padding="16,14">
                <StackPanel Spacing="4">
                  <TextBlock Text="{l:T 'streams.cta'}"
                             Foreground="#556070"
                             FontSize="{DynamicResource FontSizeSM}"
                             TextWrapping="Wrap"/>
                  <TextBlock Text="{l:T 'streams.ctaOpen'}"
                             Foreground="#4a90d6"
                             FontSize="{DynamicResource FontSizeSM}"
                             FontWeight="SemiBold"/>
                </StackPanel>
              </Border>
            </Button>

          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Border>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:api="using:d2c_launcher.Api"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:l="clr-namespace:d2c_launcher.Util"
             x:Class="d2c_launcher.Views.Components.StreamsPanel"
             x:DataType="vm:StreamsViewModel">

  <Border Classes="Block" ClipToBounds="True">
    <Grid RowDefinitions="Auto,*">

      <!-- Header -->
      <Border Grid.Row="0" Classes="BlockHead">
        <TextBlock Classes="BlockTitle" Text="{l:T 'streams.tabLabel'}"/>
      </Border>

      <!-- Content -->
      <ScrollViewer Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <Grid>

          <!-- Loading -->
          <TextBlock IsVisible="{Binding IsLoading}"
                     Text="{l:T 'common.loading'}"
                     Foreground="#888888" FontSize="{DynamicResource FontSizeSM}"
                     VerticalAlignment="Center" HorizontalAlignment="Center"
                     Margin="0,40,0,0"/>

          <!-- Empty state -->
          <TextBlock IsVisible="{Binding HasNoStreams}"
                     Text="{l:T 'streams.noStreams'}"
                     Foreground="#888888" FontSize="{DynamicResource FontSizeSM}"
                     VerticalAlignment="Center" HorizontalAlignment="Center"
                     Margin="0,40,0,0"/>

          <StackPanel IsVisible="{Binding !IsLoading}">

            <!-- Stream cards -->
            <ItemsControl ItemsSource="{Binding Streams}"
                          IsVisible="{Binding HasAnyStreams}"
                          Margin="16,16,16,8">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="api:TwitchStreamDto">
                  <Button Click="OnUrlButtonClicked"
                          Tag="{Binding Link}"
                          Background="Transparent" BorderThickness="0"
                          Padding="0" Margin="0,0,12,12"
                          Cursor="Hand" CornerRadius="0"
                          HorizontalContentAlignment="Stretch">
                    <Button.Styles>
                      <Style Selector="Button /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BoxShadow" Value="0 2 8 0 #40000000"/>
                      </Style>
                      <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BoxShadow" Value="0 4 16 0 #80000000"/>
                      </Style>
                    </Button.Styles>

                    <Border Width="272" Height="240"
                            Background="#0d1520"
                            BorderBrush="#252E3A" BorderThickness="1"
                            CornerRadius="4" ClipToBounds="True">
                      <Border.Styles>
                        <Style Selector="Button:pointerover Border">
                          <Setter Property="BorderBrush" Value="#3a5a7a"/>
                        </Style>
                      </Border.Styles>
                      <Grid RowDefinitions="Auto,*">

                        <!-- Thumbnail -->
                        <Border Grid.Row="0" Height="153" ClipToBounds="True" Background="#0a0f18">
                          <Image asyncImageLoader:ImageLoader.Source="{Binding Preview}"
                                 Stretch="UniformToFill"/>
                        </Border>

                        <!-- Info -->
                        <Grid Grid.Row="1" Margin="10,10,10,12" RowDefinitions="*,Auto">

                          <!-- Title -->
                          <TextBlock Grid.Row="0"
                                     Text="{Binding Title}"
                                     Foreground="#d0d8e0"
                                     FontSize="{DynamicResource FontSizeSM}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis"
                                     MaxLines="2"
                                     TextWrapping="Wrap"
                                     LineHeight="18"
                                     VerticalAlignment="Top"/>

                          <!-- Streamer row -->
                          <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

                            <!-- Avatar + name -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7">
                              <Border Width="20" Height="20" CornerRadius="10" ClipToBounds="True"
                                      Background="#1a2535">
                                <Image asyncImageLoader:ImageLoader.Source="{Binding User.AvatarSmall}"
                                       Stretch="UniformToFill"/>
                              </Border>
                              <TextBlock Text="{Binding User.Name}"
                                         Foreground="#5a90c0"
                                         FontSize="{DynamicResource FontSizeXS}"
                                         FontWeight="SemiBold"
                                         VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Viewer count -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5"
                                        VerticalAlignment="Center">
                              <Ellipse Width="6" Height="6" Fill="#e74c3c" VerticalAlignment="Center"/>
                              <TextBlock Text="{Binding Viewers}"
                                         Foreground="#8a9aaa" FontSize="{DynamicResource FontSizeXS}"/>
                            </StackPanel>

                          </Grid>
                        </Grid>

                      </Grid>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- CTA row -->
            <Button Click="OnUrlButtonClicked"
                    Tag="{Binding PlayerSettingsUrl}"
                    IsVisible="{Binding PlayerSettingsUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="Transparent" BorderThickness="0"
                    Padding="0" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand" CornerRadius="0">
              <Button.Styles>
                <Style Selector="Button /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="Button:pointerover /template/ ContentPresenter">
                  <Setter Property="Background" Value="#0d1118"/>
                </Style>
              </Button.Styles>
              <Border BorderBrush="#1e2a38" BorderThickness="0,1,0,0" Padding="16,14">
                <StackPanel Spacing="4">
                  <TextBlock Text="{l:T 'streams.cta'}"
                             Foreground="#556070"
                             FontSize="{DynamicResource FontSizeSM}"
                             TextWrapping="Wrap"/>
                  <TextBlock Text="{l:T 'streams.ctaOpen'}"
                             Foreground="#4a90d6"
                             FontSize="{DynamicResource FontSizeSM}"
                             FontWeight="SemiBold"/>
                </StackPanel>
              </Border>
            </Button>

          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Border>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             x:Class="d2c_launcher.Views.Components.ProfilePanel"
             x:DataType="vm:ProfileViewModel">

  <Grid RowDefinitions="Auto,*">

    <!-- Loading indicator -->
    <TextBlock Grid.Row="0" IsVisible="{Binding IsLoading}"
               Text="Загрузка профиля..." Foreground="#7a8a9a"
               FontSize="{DynamicResource FontSizeBase}"
               HorizontalAlignment="Center" Margin="0,40"/>

    <!-- Content (hidden while loading) -->
    <Grid Grid.Row="0" RowDefinitions="Auto,*" IsVisible="{Binding !IsLoading}">

      <!-- Stats header bar -->
      <Border Grid.Row="0" Background="#0A0B0D" Padding="20,14" Margin="0,0,0,12">
        <Grid ColumnDefinitions="*,Auto">
          <!-- Left: player name + W/L/D -->
          <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
            <TextBlock Text="{Binding PlayerName}"
                       FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#D9D9D9"/>
            <TextBlock Text="{Binding WinsLossesText}"
                       FontSize="{DynamicResource FontSizeMD}" Foreground="#7a8a9a"/>
          </StackPanel>

          <!-- Right: key stats -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
            <!-- Win rate -->
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <TextBlock Text="{Binding WinRateText}"
                         FontSize="{DynamicResource FontSizeXL}" FontWeight="Bold" Foreground="#4DA9F3"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="ДОЛЯ ПОБЕД" Foreground="#7a8a9a"
                         FontSize="{DynamicResource FontSizeXS}" HorizontalAlignment="Center"/>
            </StackPanel>
            <!-- MMR -->
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <TextBlock Text="{Binding Mmr}"
                         FontSize="{DynamicResource FontSizeXL}" FontWeight="Bold" Foreground="#D9D9D9"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="РЕЙТИНГ" Foreground="#7a8a9a"
                         FontSize="{DynamicResource FontSizeXS}" HorizontalAlignment="Center"/>
            </StackPanel>
            <!-- Rank -->
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <TextBlock Text="{Binding Rank}"
                         FontSize="{DynamicResource FontSizeXL}" FontWeight="Bold" Foreground="#D9D9D9"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="РАНГ" Foreground="#7a8a9a"
                         FontSize="{DynamicResource FontSizeXS}" HorizontalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Body: season KDA (left) + top heroes (right) -->
      <Grid Grid.Row="1" ColumnDefinitions="200,*" Margin="0,0,0,0">

        <!-- Left: Season KDA -->
        <Border Grid.Column="0" Background="#0A0B0D" Padding="16,14" Margin="0,0,12,0">
          <StackPanel Spacing="16">
            <TextBlock Text="СТАТИСТИКА ЗА СЕЗОН" Foreground="#7a8a9a"
                       FontSize="{DynamicResource FontSizeXS}" FontWeight="SemiBold"/>
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding AvgKills}"
                           Foreground="#4DA9F3" FontSize="{DynamicResource FontSizeLG}" FontWeight="Bold"
                           Width="64"/>
                <TextBlock Grid.Column="1" Text="Убийств" Foreground="#C0C0C0"
                           FontSize="{DynamicResource FontSizeBase}" VerticalAlignment="Center"/>
              </Grid>
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding AvgDeaths}"
                           Foreground="#e05050" FontSize="{DynamicResource FontSizeLG}" FontWeight="Bold"
                           Width="64"/>
                <TextBlock Grid.Column="1" Text="Смертей" Foreground="#C0C0C0"
                           FontSize="{DynamicResource FontSizeBase}" VerticalAlignment="Center"/>
              </Grid>
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding AvgAssists}"
                           Foreground="#7a8a9a" FontSize="{DynamicResource FontSizeLG}" FontWeight="Bold"
                           Width="64"/>
                <TextBlock Grid.Column="1" Text="Помощи" Foreground="#C0C0C0"
                           FontSize="{DynamicResource FontSizeBase}" VerticalAlignment="Center"/>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Right: Top heroes -->
        <Border Grid.Column="1" Background="#0A0B0D" Padding="16,14">
          <StackPanel Spacing="10">
            <TextBlock Text="ЛУЧШИЕ ГЕРОИ" Foreground="#7a8a9a"
                       FontSize="{DynamicResource FontSizeXS}" FontWeight="SemiBold"/>

            <!-- Table header -->
            <Grid ColumnDefinitions="*,60,80,60">
              <TextBlock Grid.Column="0" Text="ГЕРОЙ" Foreground="#4a5a6a"
                         FontSize="{DynamicResource FontSizeXS}"/>
              <TextBlock Grid.Column="1" Text="МАТЧИ" Foreground="#4a5a6a"
                         FontSize="{DynamicResource FontSizeXS}" HorizontalAlignment="Center"/>
              <TextBlock Grid.Column="2" Text="% ПОБЕД" Foreground="#4a5a6a"
                         FontSize="{DynamicResource FontSizeXS}" HorizontalAlignment="Center"/>
              <TextBlock Grid.Column="3" Text="KDA" Foreground="#4a5a6a"
                         FontSize="{DynamicResource FontSizeXS}" HorizontalAlignment="Center"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding TopHeroes}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:HeroRowViewModel">
                  <Border BorderBrush="#1a2030" BorderThickness="0,0,0,1" Padding="0,6">
                    <Grid ColumnDefinitions="*,60,80,60">
                      <TextBlock Grid.Column="0" Text="{Binding HeroName}"
                                 Foreground="#C0C0C0" FontSize="{DynamicResource FontSizeBase}"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding Games}"
                                 Foreground="#D9D9D9" FontSize="{DynamicResource FontSizeBase}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="2" Text="{Binding WinRateText}"
                                 Foreground="#4DA9F3" FontSize="{DynamicResource FontSizeBase}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="3" Text="{Binding KdaText}"
                                 Foreground="#C0C0C0" FontSize="{DynamicResource FontSizeBase}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>

</UserControl>

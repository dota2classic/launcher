<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:components="using:d2c_launcher.Views.Components"
             xmlns:res="clr-namespace:d2c_launcher.Resources"
             xmlns:l="clr-namespace:d2c_launcher.Util"
             x:Class="d2c_launcher.Views.Components.ProfilePanel"
             x:DataType="vm:ProfileViewModel">

  <UserControl.Styles>
    <!-- Hero row hover -->
    <Style Selector="Border.HeroRow:pointerover">
      <Setter Property="Background" Value="#1C2230"/>
    </Style>
    <!-- Stat row -->
    <Style Selector="Border.StatRow">
      <Setter Property="BorderBrush" Value="#181F28"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="18,10"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- Loading indicator -->
    <TextBlock Grid.Row="0" IsVisible="{Binding IsLoading}"
               Text="{x:Static res:Strings.LoadingProfile}" Foreground="#556070"
               FontSize="{DynamicResource FontSizeBase}"
               HorizontalAlignment="Center" Margin="0,40"/>
    <!-- Content -->
    <Grid Grid.Row="0" RowDefinitions="Auto,Auto,*" IsVisible="{Binding !IsLoading}">

      <!-- ── PROFILE HERO HEADER ── -->
      <Border Grid.Row="0" Background="#0A0C0F"
              BorderBrush="#252E3A" BorderThickness="0,0,0,2">
        <Grid ColumnDefinitions="3,*">
          <!-- Blue left accent strip (gradient) -->
          <Border Grid.Column="0">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="Transparent" Offset="0"/>
                <GradientStop Color="#4A9EE0" Offset="0.4"/>
                <GradientStop Color="#4A9EE0" Offset="0.6"/>
                <GradientStop Color="Transparent" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>

          <Border Grid.Column="1" Padding="20,0,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">

              <!-- Avatar -->
              <Border Grid.Column="0" Width="60" Height="60" Margin="0,14,16,14"
                      BorderBrush="#252E3A" BorderThickness="1" VerticalAlignment="Center">
                <Panel>
                  <Image asyncImageLoader:ImageLoader.Source="{Binding AvatarUrl}" Stretch="UniformToFill"
                         IsVisible="{Binding AvatarUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                  <Border Background="#1A2535"
                          IsVisible="{Binding AvatarUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                    <TextBlock Text="{Binding PlayerInitial}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSize3XL}" FontWeight="Bold" Foreground="#4A9EE0"/>
                  </Border>
                  <!-- Online dot -->
                  <Ellipse Width="9" Height="9" Fill="#52B847"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Margin="0,0,2,2"/>
                </Panel>
              </Border>

              <!-- Name + match count -->
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="5">
                <!-- Back button (only when navigated from another tab) -->
                <Button IsVisible="{Binding CanGoBack}"
                        Command="{Binding GoBackCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="0" Cursor="Hand"
                        HorizontalAlignment="Left">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="←" Foreground="#4A9EE0" FontSize="{DynamicResource FontSizeBase}"/>
                    <TextBlock Text="{x:Static res:Strings.Back}" Foreground="#4A9EE0" FontSize="{DynamicResource FontSizeBase}"/>
                  </StackPanel>
                </Button>
                <TextBlock Text="{Binding PlayerName}"
                           FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold"
                           Foreground="#FFFFFF"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding TotalGames}"
                             FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                             Foreground="#E2E6EA"/>
                  <TextBlock Text="{x:Static res:Strings.MatchesSuffix}"
                             FontSize="{DynamicResource FontSizeBase}"
                             Foreground="#99A8B4"/>
                </StackPanel>
              </StackPanel>

              <!-- Stat chips -->
              <Border Grid.Column="2" BorderBrush="#252E3A" BorderThickness="1,0,0,0"
                      VerticalAlignment="Stretch">
                <StackPanel Orientation="Horizontal">

                  <!-- Wins/Losses -->
                  <Border BorderBrush="#252E3A" BorderThickness="0,0,1,0" Padding="26,16" MinWidth="100">
                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="0">
                        <TextBlock Text="{Binding Wins}"
                                   FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#E2E6EA"/>
                        <TextBlock Text="–"
                                   FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#556070"/>
                        <TextBlock Text="{Binding Losses}"
                                   FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#D04535"/>
                        <TextBlock Text="–"
                                   FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#556070"/>
                        <TextBlock Text="{Binding Abandons}"
                                   FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#556070"/>
                      </StackPanel>
                      <TextBlock Text="МАТЧИ"
                                 FontSize="{DynamicResource FontSize2XS}" LetterSpacing="2"
                                 Foreground="#556070" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>

                  <!-- Win rate -->
                  <Border BorderBrush="#252E3A" BorderThickness="0,0,1,0" Padding="26,16" MinWidth="100">
                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                      <TextBlock Text="{Binding WinRateText}"
                                 FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#52B847"
                                 HorizontalAlignment="Center"/>
                      <TextBlock Text="{x:Static res:Strings.WinRate}"
                                 FontSize="{DynamicResource FontSize2XS}" LetterSpacing="2"
                                 Foreground="#556070" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>

                  <!-- MMR -->
                  <Border BorderBrush="#252E3A" BorderThickness="0,0,1,0" Padding="26,16" MinWidth="100">
                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                      <TextBlock Text="{Binding Mmr}"
                                 FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#D4A843"
                                 HorizontalAlignment="Center"/>
                      <TextBlock Text="{x:Static res:Strings.ColRating}"
                                 FontSize="{DynamicResource FontSize2XS}" LetterSpacing="2"
                                 Foreground="#556070" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>

                  <!-- Rank -->
                  <Border Padding="26,16" MinWidth="100">
                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                      <TextBlock Text="{Binding Rank}"
                                 FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#E2E6EA"
                                 HorizontalAlignment="Center"/>
                      <TextBlock Text="{x:Static res:Strings.ColRank}"
                                 FontSize="{DynamicResource FontSize2XS}" LetterSpacing="2"
                                 Foreground="#556070" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>

                </StackPanel>
              </Border>

            </Grid>
          </Border>
        </Grid>
      </Border>

      <!-- ── PROFILE SUB-TABS ── -->
      <Border Grid.Row="1" Background="#0A0C0F"
              BorderBrush="#252E3A" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" Margin="24,0,0,0">
          <Border Classes="SubTab" Classes.SubTabActive="{Binding IsGeneralTabActive}"
                  Margin="0,0,0,-1" Tapped="OnGeneralTabTapped">
            <TextBlock Classes="SubTabText" Classes.SubTabTextActive="{Binding IsGeneralTabActive}"
                       Text="{l:T 'profile.tabGeneral'}"/>
          </Border>
          <Border Classes="SubTab" Classes.SubTabActive="{Binding IsSubscriptionTabActive}"
                  IsVisible="{Binding IsOwner}"
                  Margin="0,0,0,-1" Tapped="OnSubscriptionTabTapped">
            <TextBlock Classes="SubTabText" Classes.SubTabTextActive="{Binding IsSubscriptionTabActive}"
                       Text="{l:T 'profile.tabSubscription'}"/>
          </Border>
        </StackPanel>
      </Border>

      <!-- ── CONTENT: General tab ── -->
      <ScrollViewer Grid.Row="2" IsVisible="{Binding IsGeneralTabActive}"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20" HorizontalAlignment="Stretch">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- ── BLOCK 1: Отзывы ── -->
          <Border Grid.Column="0" Classes="Block">
            <Grid RowDefinitions="36,*">
              <Border Grid.Row="0" Classes="BlockHead">
                <TextBlock Classes="BlockTitle" Text="{x:Static res:Strings.ColAssists}"/>
              </Border>
              <Border Grid.Row="1" Padding="16,20,16,16">
                <components:PentagonControl Aspects="{Binding Aspects}"
                                            Width="240" Height="230"
                                            HorizontalAlignment="Center"/>
              </Border>
            </Grid>
          </Border>

          <!-- ── BLOCK 2: Статистика за сезон ── -->
          <Border Grid.Column="2" Classes="Block">
            <Grid RowDefinitions="36,*">
              <Border Grid.Row="0" Classes="BlockHead">
                <TextBlock Classes="BlockTitle" Text="{x:Static res:Strings.SeasonStats}"/>
              </Border>
              <StackPanel Grid.Row="1" Spacing="0">

                <!-- KDA group -->
                <Border Classes="StatRow">
                  <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="{Binding AvgKills}"
                               FontSize="{DynamicResource FontSize2XL}" FontWeight="SemiBold" Foreground="#D4A843"/>
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.Kills}" Foreground="#99A8B4"
                               FontSize="{DynamicResource FontSizeMD}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>
                <Border Classes="StatRow">
                  <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="{Binding AvgDeaths}"
                               FontSize="{DynamicResource FontSize2XL}" FontWeight="SemiBold" Foreground="#4A9EE0"/>
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.Deaths}" Foreground="#99A8B4"
                               FontSize="{DynamicResource FontSizeMD}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>
                <Border Classes="StatRow">
                  <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="{Binding AvgAssists}"
                               FontSize="{DynamicResource FontSize2XL}" FontWeight="SemiBold" Foreground="#D4A843"/>
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.Assists}" Foreground="#99A8B4"
                               FontSize="{DynamicResource FontSizeMD}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>

                <!-- Divider -->
                <Border Height="1" Background="#252E3A" Margin="0,4"/>
                <!-- General group -->
                <Border Classes="StatRow">
                  <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="{Binding TotalGames}"
                               FontSize="{DynamicResource FontSizeXL}" FontWeight="SemiBold" Foreground="#E2E6EA"/>
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.GamesPlayed}" Foreground="#99A8B4"
                               FontSize="{DynamicResource FontSizeMD}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>
                <Border Classes="StatRow">
                  <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="{Binding WinRateText}"
                               FontSize="{DynamicResource FontSizeXL}" FontWeight="SemiBold" Foreground="#52B847"/>
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.WinRateLabel}" Foreground="#99A8B4"
                               FontSize="{DynamicResource FontSizeMD}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>
                <Border Classes="StatRow">
                  <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="{Binding AbandonRateText}"
                               FontSize="{DynamicResource FontSizeXL}" FontWeight="SemiBold" Foreground="#556070"/>
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.AbandonedGames}" Foreground="#99A8B4"
                               FontSize="{DynamicResource FontSizeMD}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>
                <Border BorderBrush="#181F28" BorderThickness="0,0,0,0" Padding="18,10">
                  <Grid ColumnDefinitions="110,*">
                    <TextBlock Grid.Column="0" Text="{Binding PlaytimeText}"
                               FontSize="{DynamicResource FontSizeLG}" FontWeight="SemiBold" Foreground="#E2E6EA"/>
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.TimeInGame}" Foreground="#99A8B4"
                               FontSize="{DynamicResource FontSizeMD}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>

              </StackPanel>
            </Grid>
          </Border>

          <!-- ── BLOCK 3: Лучшие герои ── -->
          <Border Grid.Column="4" Classes="Block">
            <Grid RowDefinitions="36,Auto,*">

              <!-- Block header -->
              <Border Grid.Row="0" Classes="BlockHead">
                <Grid>
                  <TextBlock Classes="BlockTitle" Text="{x:Static res:Strings.BestHeroes}" VerticalAlignment="Center"/>
                  <TextBlock Text="{x:Static res:Strings.ShowAll}" Foreground="#4A9EE0"
                             FontSize="{DynamicResource FontSizeSM}" HorizontalAlignment="Right"
                             VerticalAlignment="Center" Cursor="Hand"/>
                </Grid>
              </Border>

              <!-- Table column headers -->
              <Border Grid.Row="1" Background="#0D1017"
                      BorderBrush="#252E3A" BorderThickness="0,0,0,1"
                      Padding="18,8">
                <Grid ColumnDefinitions="*,52,88,52">
                  <TextBlock Grid.Column="0" Text="{x:Static res:Strings.ColHero}" Foreground="#556070"
                             FontSize="{DynamicResource FontSize2XS}" LetterSpacing="2"/>
                  <TextBlock Grid.Column="1" Text="МАТЧИ" Foreground="#556070"
                             FontSize="{DynamicResource FontSize2XS}" LetterSpacing="2"
                             HorizontalAlignment="Center"/>
                  <TextBlock Grid.Column="2" Text="% ПОБЕД" Foreground="#556070"
                             FontSize="{DynamicResource FontSize2XS}" LetterSpacing="2"
                             HorizontalAlignment="Center"/>
                  <TextBlock Grid.Column="3" Text="KDA" Foreground="#556070"
                             FontSize="{DynamicResource FontSize2XS}" LetterSpacing="2"
                             HorizontalAlignment="Center"/>
                </Grid>
              </Border>

              <!-- Hero rows -->
              <ItemsControl Grid.Row="2" ItemsSource="{Binding TopHeroes}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:HeroRowViewModel">
                    <Border Classes="HeroRow"
                            BorderBrush="#181F28" BorderThickness="0,0,0,1"
                            Padding="18,8" Background="Transparent">
                      <Grid ColumnDefinitions="*,52,88,52">

                        <!-- Hero name + image -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9"
                                    VerticalAlignment="Center">
                          <Border Width="34" Height="24" ClipToBounds="True"
                                  BorderBrush="#252E3A" BorderThickness="1"
                                  Background="#1A2030">
                            <Image asyncImageLoader:ImageLoader.Source="{Binding HeroImageUrl}"
                                   Stretch="UniformToFill"/>
                          </Border>
                          <TextBlock Text="{Binding HeroName}"
                                     Foreground="#4A9EE0"
                                     FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                                     VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Match count -->
                        <TextBlock Grid.Column="1" Text="{Binding Games}"
                                   Foreground="#E2E6EA"
                                   FontSize="{DynamicResource FontSizeMD}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- Win rate + bar -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Spacing="4">
                          <TextBlock Text="{Binding WinRateText}"
                                     Foreground="{Binding WinRateBrush}"
                                     FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                                     HorizontalAlignment="Center"/>
                          <Border Height="2" Width="52" Background="#252E3A" HorizontalAlignment="Center">
                            <Border HorizontalAlignment="Left" Height="2"
                                    Width="{Binding WinRateBarWidth}"
                                    Background="{Binding WinRateBrush}"/>
                          </Border>
                        </StackPanel>

                        <!-- KDA -->
                        <TextBlock Grid.Column="3" Text="{Binding KdaText}"
                                   Foreground="#D4A843"
                                   FontSize="{DynamicResource FontSizeMD}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

            </Grid>
          </Border>

        </Grid>
      </ScrollViewer>

      <!-- ── CONTENT: Subscription tab ── -->
      <ScrollViewer Grid.Row="2" IsVisible="{Binding IsSubscriptionTabActive}"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20" Spacing="16">

          <!-- Loading spinner -->
          <TextBlock IsVisible="{Binding IsSubscriptionDataLoading}"
                     Text="{l:T 'profile.loading'}" Foreground="#556070"
                     FontSize="{DynamicResource FontSizeBase}"
                     HorizontalAlignment="Center" Margin="0,20"/>

          <!-- Subscription status block -->
          <Border IsVisible="{Binding !IsSubscriptionDataLoading}" Classes="Block">
            <Grid RowDefinitions="36,*">
              <Border Grid.Row="0" Classes="BlockHead">
                <TextBlock Classes="BlockTitle" Text="{l:T 'profile.subscriptionStatus'}"/>
              </Border>
              <Border Grid.Row="1" Padding="18,14">
                <StackPanel Spacing="10">

                  <!-- Active subscription -->
                  <StackPanel IsVisible="{Binding HasPlusSubscription}" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="✦" Foreground="#C8A84B"
                                 FontSize="{DynamicResource FontSizeLG}" VerticalAlignment="Center"/>
                      <TextBlock Text="{l:T 'profile.subscriptionActive'}"
                                 Foreground="#C8A84B" FontWeight="SemiBold"
                                 FontSize="{DynamicResource FontSizeLG}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{l:T 'profile.subscriptionExpires'}"
                                 Foreground="#556070" FontSize="{DynamicResource FontSizeMD}"/>
                      <TextBlock Text="{Binding PlusSubscriptionEndText}"
                                 Foreground="#99A8B4" FontSize="{DynamicResource FontSizeMD}"
                                 FontWeight="SemiBold"/>
                    </StackPanel>
                  </StackPanel>

                  <!-- No active subscription -->
                  <TextBlock IsVisible="{Binding !HasPlusSubscription}"
                             Text="{l:T 'profile.subscriptionNone'}"
                             Foreground="#556070" FontSize="{DynamicResource FontSizeMD}"/>

                  <!-- Buy / renew button -->
                  <Button Command="{Binding OpenStoreCommand}"
                          Background="#C8A84B" Foreground="#0A0C0F"
                          BorderThickness="0" Padding="14,6" CornerRadius="2"
                          Cursor="Hand" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding StoreButtonText}"
                               FontSize="{DynamicResource FontSizeMD}" FontWeight="SemiBold"/>
                  </Button>

                </StackPanel>
              </Border>
            </Grid>
          </Border>

          <!-- Dodge list block -->
          <Border IsVisible="{Binding !IsSubscriptionDataLoading}" Classes="Block">
            <Grid RowDefinitions="36,*">
              <Border Grid.Row="0" Classes="BlockHead">
                <TextBlock Classes="BlockTitle" Text="{l:T 'profile.dodgeList'}"/>
              </Border>
              <StackPanel Grid.Row="1">

                <!-- Empty state -->
                <TextBlock IsVisible="{Binding !DodgeList.Count}"
                           Text="{l:T 'profile.dodgeListEmpty'}"
                           Foreground="#556070" FontSize="{DynamicResource FontSizeMD}"
                           Padding="18,14"/>

                <!-- Dodge entries -->
                <ItemsControl ItemsSource="{Binding DodgeList}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DodgeEntryViewModel">
                      <Border BorderBrush="#181F28" BorderThickness="0,0,0,1"
                              Padding="18,10" Background="Transparent">
                        <Grid ColumnDefinitions="Auto,*,Auto">

                          <!-- Avatar -->
                          <Border Grid.Column="0" Width="32" Height="32" Margin="0,0,12,0"
                                  ClipToBounds="True" BorderBrush="#252E3A" BorderThickness="1"
                                  Background="#1A2030">
                            <Image asyncImageLoader:ImageLoader.Source="{Binding AvatarUrl}"
                                   Stretch="UniformToFill"
                                   IsVisible="{Binding AvatarUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                          </Border>

                          <!-- Name + date -->
                          <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#E2E6EA" FontSize="{DynamicResource FontSizeBase}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding AddedDateText}"
                                       Foreground="#556070" FontSize="{DynamicResource FontSizeSM}"/>
                          </StackPanel>

                          <!-- Remove button -->
                          <Button Grid.Column="2" Classes="DangerButton"
                                  Command="{Binding RemoveDodgeCommand}"
                                  IsEnabled="{Binding !IsRemoving}"
                                  Padding="10,4" CornerRadius="2" Cursor="Hand"
                                  VerticalAlignment="Center">
                            <TextBlock Text="{l:T 'profile.removeFromDodge'}"
                                       FontSize="{DynamicResource FontSizeSM}"/>
                          </Button>

                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add to dodge button -->
                <Border Padding="18,12">
                  <Button Command="{Binding OpenDodgeSearchCommand}"
                          Background="#252E3A" Foreground="#E2E6EA"
                          BorderThickness="0" Padding="14,6" CornerRadius="2"
                          Cursor="Hand" HorizontalAlignment="Left">
                    <TextBlock Text="{l:T 'profile.dodgeAdd'}"
                               FontSize="{DynamicResource FontSizeMD}" FontWeight="SemiBold"/>
                  </Button>
                </Border>

              </StackPanel>
            </Grid>
          </Border>

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Grid>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             x:Class="d2c_launcher.Views.Components.QueueButton"
             x:DataType="vm:QueueViewModel">

  <Button Height="80" HorizontalAlignment="Stretch"
          HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
          Background="{Binding QueueButtonBackground}" Foreground="White"
          BorderBrush="{Binding QueueButtonBorderBrush}" BorderThickness="1" CornerRadius="0"
          Padding="18,18" Click="OnQueueButtonClicked">
      <Button.Styles>
          <Style Selector="Button:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="{Binding QueueButtonHoverBackground}"/>
          </Style>
      </Button.Styles>
      <StackPanel HorizontalAlignment="Center" Spacing="4">
          <TextBlock Text="{Binding QueueButtonMainText}" HorizontalAlignment="Center"
                     FontFamily="{StaticResource TrajanPro3}" FontWeight="Bold"
                     FontSize="{DynamicResource FontSize2XL}" Foreground="White" LetterSpacing="1"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12"
                      IsVisible="{Binding IsSearching}">
              <TextBlock Text="{Binding QueueButtonModeCountText}" Foreground="White"
                         FontFamily="{StaticResource TrajanPro3}"
                         FontSize="{DynamicResource FontSizeSM}" FontWeight="Normal"
                         VerticalAlignment="Center" LetterSpacing="1"/>
              <TextBlock Text="{Binding QueueButtonTimeText}" Foreground="#F5D042"
                         FontFamily="{StaticResource TrajanPro3}"
                         FontSize="{DynamicResource FontSizeSM}" FontWeight="Bold"
                         VerticalAlignment="Center" LetterSpacing="1"/>
          </StackPanel>
      </StackPanel>
  </Button>
</UserControl>

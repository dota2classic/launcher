<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="using:d2c_launcher.Views.Components"
             x:Class="d2c_launcher.Views.Components.ModalOverlay"
             x:Name="Root">
   <Panel IsVisible="{Binding IsOpen, ElementName=Root}"
          Background="#AA000000"
          PointerPressed="OnOverlayPointerPressed">
       <Border HorizontalAlignment="Center" VerticalAlignment="Center"
               MinWidth="360" MaxWidth="560"
               Background="#151515" BorderBrush="#2A2A2A" BorderThickness="1"
               CornerRadius="0" Padding="0"
               BoxShadow="0 12 28 0 #80000000"
               PointerPressed="OnDialogPointerPressed">
           <StackPanel>
               <components:ModalHeader Title="{Binding Title, ElementName=Root}"
                                       CloseRequested="OnModalHeaderCloseRequested"/>
               <ContentPresenter Content="{Binding ModalContent, ElementName=Root}"
                                 Margin="0"/>
           </StackPanel>
       </Border>
   </Panel>
</UserControl>

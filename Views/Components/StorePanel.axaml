<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:l="clr-namespace:d2c_launcher.Util"
             x:Class="d2c_launcher.Views.Components.StorePanel"
             x:DataType="vm:StoreViewModel">

  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="2" MaxWidth="850" HorizontalAlignment="Center">

      <!-- ═══ HERO BANNER ═══ -->
      <Panel MinHeight="220" ClipToBounds="True">
        <!-- Full-bleed hero image -->
        <Image Source="avares://d2c-launcher/Assets/Images/splash/subscription.webp"
               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Fully opaque dark left half, fading to transparent on the right -->
        <Border>
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="#FF09090b" Offset="0"/>
              <GradientStop Color="#FF09090b" Offset="0.42"/>
              <GradientStop Color="#C009090b" Offset="0.58"/>
              <GradientStop Color="#5009090b" Offset="0.76"/>
              <GradientStop Color="#0009090b" Offset="0.92"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <!-- Text content -->
        <StackPanel VerticalAlignment="Center" Margin="44,36">

          <!-- Title -->
          <Border Background="#65000000" CornerRadius="3" Padding="14,8"
                  HorizontalAlignment="Left" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="16">
              <TextBlock Text="✦" Foreground="#C8A84B"
                         FontSize="{DynamicResource FontSize4XL}" VerticalAlignment="Center"/>
              <TextBlock Text="DOTACLASSIC PLUS" Foreground="#C8A84B"
                         FontSize="{DynamicResource FontSize4XL}" FontWeight="Bold"
                         LetterSpacing="4" VerticalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Tagline -->
          <TextBlock Text="{l:T 'store.heroDesc'}"
                     Foreground="#8090A4" FontSize="{DynamicResource FontSizeLG}"
                     TextWrapping="Wrap" MaxWidth="420" Margin="0,0,0,20"/>

          <!-- Loading -->
          <TextBlock IsVisible="{Binding IsLoading}"
                     Text="{l:T 'profile.loading'}"
                     Foreground="#556070" FontSize="{DynamicResource FontSizeMD}"
                     Margin="0,0,0,12"/>

          <!-- Active subscription — card backdrop -->
          <Border IsVisible="{Binding HasPlusSubscription}"
                  Background="#60000000" CornerRadius="3"
                  BorderBrush="#30C8A84B" BorderThickness="1"
                  Padding="14,10" HorizontalAlignment="Left" Margin="0,0,0,18">
            <StackPanel Spacing="5">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="✦" Foreground="#C8A84B"
                           FontSize="{DynamicResource FontSizeMD}" VerticalAlignment="Center"/>
                <TextBlock Text="{l:T 'store.subscriptionActive'}" Foreground="#C8A84B"
                           FontSize="{DynamicResource FontSizeMD}" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{l:T 'store.subscriptionExpires'}"
                           Foreground="#556070" FontSize="{DynamicResource FontSizeMD}"/>
                <TextBlock Text="{Binding PlusSubscriptionEndText}"
                           Foreground="#99A8B4" FontSize="{DynamicResource FontSizeMD}"
                           FontWeight="SemiBold"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- No subscription -->
          <TextBlock IsVisible="{Binding !HasPlusSubscription}"
                     Text="{l:T 'store.subscriptionNone'}"
                     Foreground="#556070" FontSize="{DynamicResource FontSizeMD}"
                     Margin="0,0,0,18"/>

          <!-- CTA button -->
          <Button Classes="PrimaryButton" Command="{Binding OpenTelegramCommand}"
                  IsVisible="{Binding !IsLoading}"
                  Padding="22,10" CornerRadius="2" Cursor="Hand"
                  HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Image Source="avares://d2c-launcher/Assets/Images/telegram.png"
                     Width="16" Height="16" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding StoreButtonText}"
                         FontSize="{DynamicResource FontSizeMD}" FontWeight="Bold"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Panel>

      <!-- ─── Section divider ─── -->
      <Border Background="#0d0f13" Padding="44,14">
        <TextBlock Text="{l:T 'store.benefitsTitle'}"
                   Foreground="#3a4860" FontSize="{DynamicResource FontSizeXS}"
                   FontWeight="SemiBold" LetterSpacing="3"/>
      </Border>

      <!-- ═══ FEATURE 1 — decorations ═══ -->
      <Panel MinHeight="300" ClipToBounds="True">
        <Image Source="avares://d2c-launcher/Assets/Images/splash/decoration.webp"
               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <!-- light uniform overlay -->
        <Border Background="#60000000"/>
        <!-- top vignette — shadow behind title -->
        <Border VerticalAlignment="Top" Height="110">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#A0000000" Offset="0"/>
              <GradientStop Color="#00000000" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>
        <!-- bottom fade for description readability -->
        <Border VerticalAlignment="Bottom" Height="130">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#00000000" Offset="0"/>
              <GradientStop Color="#88000000" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>
        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#65000000" CornerRadius="3"
                Margin="60,32,60,0" Padding="20,8">
          <TextBlock Text="{l:T 'store.benefit1Title'}"
                   Foreground="#C8A84B" FontSize="{DynamicResource FontSize4XL}"
                   FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
        <TextBlock Text="{l:T 'store.benefit1Desc'}"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="100,0,100,28"
                   Foreground="#C0C8D8" FontSize="{DynamicResource FontSizeLG}"
                   TextWrapping="Wrap" TextAlignment="Center"/>
      </Panel>

      <!-- ═══ FEATURE 2 — dodge ═══ -->
      <Panel MinHeight="300" ClipToBounds="True">
        <Image Source="avares://d2c-launcher/Assets/Images/splash/dodge.webp"
               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Border Background="#60000000"/>
        <Border VerticalAlignment="Bottom" Height="130">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#00000000" Offset="0"/>
              <GradientStop Color="#88000000" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>
        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#65000000" CornerRadius="3"
                Margin="60,32,60,0" Padding="20,8">
          <TextBlock Text="{l:T 'store.benefit2Title'}"
                   Foreground="#C8A84B" FontSize="{DynamicResource FontSize4XL}"
                   FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
        <TextBlock Text="{l:T 'store.benefit2Desc'}"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="100,0,100,28"
                   Foreground="#C0C8D8" FontSize="{DynamicResource FontSizeLG}"
                   TextWrapping="Wrap" TextAlignment="Center"/>
      </Panel>

      <!-- ═══ FEATURE 3 — unban ═══ -->
      <Panel MinHeight="300" ClipToBounds="True">
        <Image Source="avares://d2c-launcher/Assets/Images/splash/unban.webp"
               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Border Background="#60000000"/>
        <Border VerticalAlignment="Bottom" Height="130">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#00000000" Offset="0"/>
              <GradientStop Color="#88000000" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>
        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#65000000" CornerRadius="3"
                Margin="60,32,60,0" Padding="20,8">
          <TextBlock Text="{l:T 'store.benefit3Title'}"
                   Foreground="#C8A84B" FontSize="{DynamicResource FontSize4XL}"
                   FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
        <TextBlock Text="{l:T 'store.benefit3Desc'}"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="100,0,100,28"
                   Foreground="#C0C8D8" FontSize="{DynamicResource FontSizeLG}"
                   TextWrapping="Wrap" TextAlignment="Center"/>
      </Panel>

      <!-- ═══ FEATURE 4 — in-game praise ═══ -->
      <Panel MinHeight="300" ClipToBounds="True">
        <Image Source="avares://d2c-launcher/Assets/Images/splash/cm_lina.webp"
               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Border Background="#60000000"/>
        <Border VerticalAlignment="Bottom" Height="130">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#00000000" Offset="0"/>
              <GradientStop Color="#88000000" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>
        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#65000000" CornerRadius="3"
                Margin="60,32,60,0" Padding="20,8">
          <TextBlock Text="{l:T 'store.benefit4Title'}"
                   Foreground="#C8A84B" FontSize="{DynamicResource FontSize4XL}"
                   FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
        <TextBlock Text="{l:T 'store.benefit4Desc'}"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="100,0,100,28"
                   Foreground="#C0C8D8" FontSize="{DynamicResource FontSizeLG}"
                   TextWrapping="Wrap" TextAlignment="Center"/>
      </Panel>

      <!-- ═══ FEATURE 5 — mute ═══ -->
      <Panel MinHeight="300" ClipToBounds="True">
        <Image Source="avares://d2c-launcher/Assets/Images/splash/mute.webp"
               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Border Background="#60000000"/>
        <Border VerticalAlignment="Bottom" Height="130">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#00000000" Offset="0"/>
              <GradientStop Color="#88000000" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>
        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#65000000" CornerRadius="3"
                Margin="60,32,60,0" Padding="20,8">
          <TextBlock Text="{l:T 'store.benefit5Title'}"
                   Foreground="#C8A84B" FontSize="{DynamicResource FontSize4XL}"
                   FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
        <TextBlock Text="{l:T 'store.benefit5Desc'}"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="100,0,100,28"
                   Foreground="#C0C8D8" FontSize="{DynamicResource FontSizeLG}"
                   TextWrapping="Wrap" TextAlignment="Center"/>
      </Panel>

      <!-- ═══ FEATURE 6 — lobby ═══ -->
      <Panel MinHeight="300" ClipToBounds="True">
        <Image Source="avares://d2c-launcher/Assets/Images/splash/lobby.webp"
               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Border Background="#60000000"/>
        <Border VerticalAlignment="Bottom" Height="130">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#00000000" Offset="0"/>
              <GradientStop Color="#88000000" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>
        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#65000000" CornerRadius="3"
                Margin="60,32,60,0" Padding="20,8">
          <TextBlock Text="{l:T 'store.benefit6Title'}"
                   Foreground="#C8A84B" FontSize="{DynamicResource FontSize4XL}"
                   FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
        <TextBlock Text="{l:T 'store.benefit6Desc'}"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="100,0,100,28"
                   Foreground="#C0C8D8" FontSize="{DynamicResource FontSizeLG}"
                   TextWrapping="Wrap" TextAlignment="Center"/>
      </Panel>

      <!-- ═══ BOTTOM CTA ═══ -->
      <Border Padding="44,32">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#09090b" Offset="0"/>
            <GradientStop Color="#16120a" Offset="0.55"/>
            <GradientStop Color="#09090b" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
        <StackPanel Spacing="14" HorizontalAlignment="Left">
          <TextBlock Text="{l:T 'store.ctaTitle'}"
                     Foreground="#E2E6EA" FontSize="{DynamicResource FontSize2XL}"
                     FontWeight="Bold"/>
          <Button Classes="PrimaryButton" Command="{Binding OpenTelegramCommand}"
                  IsVisible="{Binding !IsLoading}"
                  Padding="22,10" CornerRadius="2" Cursor="Hand"
                  HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Image Source="avares://d2c-launcher/Assets/Images/telegram.png"
                     Width="16" Height="16" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding StoreButtonText}"
                         FontSize="{DynamicResource FontSizeMD}" FontWeight="Bold"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

</UserControl>

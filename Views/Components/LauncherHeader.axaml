<UserControl xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:vm="using:d2c_launcher.ViewModels"
           xmlns:materialIcons="using:Material.Icons.Avalonia"
           x:Class="d2c_launcher.Views.Components.LauncherHeader"
           x:DataType="vm:MainLauncherViewModel">
  <UserControl.Styles>
    <Style Selector="Button.play-btn">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="Padding" Value="28,10"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="MinWidth" Value="110"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#1a5aaa" Offset="0"/>
          <GradientStop Color="#3a90d6" Offset="1"/>
        </LinearGradientBrush>
      </Setter>
    </Style>
    <Style Selector="Button.play-btn.play-stop">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#7a1a1a" Offset="0"/>
          <GradientStop Color="#c03030" Offset="1"/>
        </LinearGradientBrush>
      </Setter>
    </Style>
    <Style Selector="Button.settings-icon">
      <Setter Property="Width" Value="44"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
  </UserControl.Styles>

  <Grid Margin="20,14">
    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
      <Button x:Name="PlayButton" Classes="play-btn"
              VerticalAlignment="Stretch"
              Classes.play-stop="{Binding Launch.PlayButtonIsStop}"
              Content="{Binding Launch.PlayButtonText}"
              Click="OnPlayClicked"/>
      <Button x:Name="SettingsButton" Classes="settings-icon" VerticalAlignment="Stretch" Click="OnSettingsClicked">
        <materialIcons:MaterialIcon Kind="Cog" Width="24" Height="24"/>
      </Button>
      <Border VerticalAlignment="Stretch" Padding="10,8" CornerRadius="0"
              Background="#242c34">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <!-- Avatar with online dot -->
          <Grid Width="36" Height="36">
            <Border Width="36" Height="36" CornerRadius="0" ClipToBounds="True"
                    Background="#2d3842">
              <Image Source="{Binding AvatarImage}" Width="36" Height="36" Stretch="UniformToFill"/>
            </Border>
            <!-- Online indicator dot -->
            <Ellipse Width="10" Height="10" Fill="#4CAF50"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-2,-2">
              <Ellipse.Stroke>
                <SolidColorBrush Color="#242c34"/>
              </Ellipse.Stroke>
              <Ellipse.StrokeThickness>2</Ellipse.StrokeThickness>
            </Ellipse>
          </Grid>
          <StackPanel VerticalAlignment="Center" Spacing="1">
            <TextBlock Text="Вы:" Foreground="#7a8a9a" FontSize="10"/>
            <TextBlock Text="{Binding CurrentUser.PersonaName}"
                       FontWeight="SemiBold" FontSize="13"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:vm="using:d2c_launcher.ViewModels"
           xmlns:materialIcons="using:Material.Icons.Avalonia"
           x:Class="d2c_launcher.Views.Components.LauncherHeader"
           x:DataType="vm:MainLauncherViewModel">
  <UserControl.Styles>
    <Style Selector="Button.nav-tab">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="24,0"/>
      <Setter Property="Foreground" Value="#4a5668"/>
      <Setter Property="FontFamily" Value="Trajan Pro, Trajan, Times New Roman, serif"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.nav-tab /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.nav-tab:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.nav-tab:pointerover TextBlock.nav-label">
      <Setter Property="Foreground" Value="#8a9aaa"/>
    </Style>
    <Style Selector="Button.nav-tab.active TextBlock.nav-label">
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.nav-tab Rectangle.nav-indicator">
      <Setter Property="Fill" Value="Transparent"/>
    </Style>
    <Style Selector="Button.nav-tab.active Rectangle.nav-indicator">
      <Setter Property="Fill" Value="#4a7eff"/>
    </Style>
    <!-- Settings button -->
    <Style Selector="Button#SettingsButton materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#4a5668"/>
    </Style>
    <Style Selector="Button#SettingsButton /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button#SettingsButton:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button#SettingsButton:pointerover materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#b0bac6"/>
    </Style>
    <Style Selector="Button#SettingsButton.active materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="White"/>
    </Style>
  </UserControl.Styles>

  <Border BorderBrush="#1e2530" BorderThickness="0">
    <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0,12,0">

      <!-- Left: navigation tabs -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Stretch">
        <Button x:Name="PlayTabButton" Classes="nav-tab" Classes.active="{Binding IsPlayTabActive}" Click="OnPlayTabClicked">
          <Grid RowDefinitions="*,2">
            <TextBlock Grid.Row="0" Classes="nav-label" Text="ИГРА"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       LetterSpacing="2"/>
            <Rectangle Grid.Row="1" Classes="nav-indicator"
                       HorizontalAlignment="Stretch"/>
          </Grid>
        </Button>
        <Button x:Name="LiveTabButton" Classes="nav-tab" Classes.active="{Binding IsLiveTabActive}" Click="OnLiveTabClicked">
          <Grid RowDefinitions="*,2">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
              <Ellipse Width="7" Height="7" Fill="#27AE60" VerticalAlignment="Center"/>
              <TextBlock Classes="nav-label" Text="LIVE" LetterSpacing="2"/>
            </StackPanel>
            <Rectangle Grid.Row="1" Classes="nav-indicator"
                       HorizontalAlignment="Stretch"/>
          </Grid>
        </Button>
      </StackPanel>

      <!-- Center: queue searching indicator -->
      <Border Grid.Column="1" IsVisible="{Binding Queue.IsSearching}"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Background="#0d2a1a" BorderBrush="#27AE60" BorderThickness="1"
              CornerRadius="0" Padding="12,6">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Ellipse Width="8" Height="8" Fill="#27AE60" VerticalAlignment="Center"/>
          <TextBlock Text="Поиск игры" Foreground="#27AE60"
                     FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding Queue.QueueButtonTimeText}"
                     Foreground="#7ab57a" FontSize="{DynamicResource FontSizeBase}"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Right: launch button + settings gear + user avatar -->
      <StackPanel Grid.Column="2" Orientation="Horizontal">
        <Button x:Name="LaunchGameButton" VerticalAlignment="Stretch" Margin="0,6,8,6"
                Padding="20,8" CornerRadius="2" Cursor="Hand"
                Click="OnLaunchGameClicked"
                Classes.stop="{Binding Launch.PlayButtonIsStop}"
                BorderThickness="0">
          <Button.Styles>
            <Style Selector="Button#LaunchGameButton">
              <Setter Property="Background" Value="#1a6b35"/>
            </Style>
            <Style Selector="Button#LaunchGameButton:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="#22884a"/>
            </Style>
            <Style Selector="Button#LaunchGameButton.stop">
              <Setter Property="Background" Value="#7b1e1e"/>
            </Style>
            <Style Selector="Button#LaunchGameButton.stop:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="#9e2828"/>
            </Style>
          </Button.Styles>
          <TextBlock Text="{Binding Launch.PlayButtonText}"
                     FontWeight="SemiBold" FontSize="{DynamicResource FontSizeMD}"
                     Foreground="White" VerticalAlignment="Center"/>
        </Button>
        <Button x:Name="SettingsButton" VerticalAlignment="Stretch" Padding="10,8"
                Background="Transparent" BorderThickness="0" CornerRadius="0"
                Cursor="Hand" Click="OnSettingsTabClicked"
                Classes.active="{Binding IsSettingsTabActive}">
          <materialIcons:MaterialIcon Kind="Cog" Width="20" Height="20"/>
        </Button>
        <Button x:Name="ProfileButton" VerticalAlignment="Stretch" Padding="10,8"
                Background="Transparent" BorderThickness="0" CornerRadius="0"
                Cursor="Hand" Click="OnProfileTabClicked">
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Grid Width="32" Height="32">
              <Border Width="32" Height="32" CornerRadius="0" ClipToBounds="True"
                      Background="#2d3842">
                <Image Source="{Binding AvatarImage}" Width="32" Height="32" Stretch="UniformToFill"/>
              </Border>
              <Ellipse Width="9" Height="9" Fill="#4CAF50"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,-2,-2">
                <Ellipse.Stroke>
                  <SolidColorBrush Color="#1e2530"/>
                </Ellipse.Stroke>
                <Ellipse.StrokeThickness>2</Ellipse.StrokeThickness>
              </Ellipse>
            </Grid>
            <TextBlock Text="{Binding CurrentUser.PersonaName}"
                       FontWeight="SemiBold" FontSize="{DynamicResource FontSizeMD}"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>

    </Grid>
  </Border>
</UserControl>

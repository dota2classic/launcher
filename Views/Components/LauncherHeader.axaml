<UserControl xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:vm="using:d2c_launcher.ViewModels"
           xmlns:materialIcons="using:Material.Icons.Avalonia"
           xmlns:res="clr-namespace:d2c_launcher.Resources"
           x:Class="d2c_launcher.Views.Components.LauncherHeader"
           x:DataType="vm:MainLauncherViewModel">
  <UserControl.Styles>
    <Style Selector="Button.nav-tab">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="24,0"/>
      <Setter Property="Foreground" Value="#4a5668"/>
      <Setter Property="FontFamily" Value="Trajan Pro, Trajan, Times New Roman, serif"/>
      <Setter Property="FontSize" Value="{DynamicResource FontSizeMD}"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.nav-tab /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.nav-tab:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.nav-tab:pointerover TextBlock.nav-label">
      <Setter Property="Foreground" Value="#8a9aaa"/>
    </Style>
    <Style Selector="Button.nav-tab.active TextBlock.nav-label">
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.nav-tab Rectangle.nav-indicator">
      <Setter Property="Fill" Value="Transparent"/>
    </Style>
    <Style Selector="Button.nav-tab.active Rectangle.nav-indicator">
      <Setter Property="Fill" Value="#4a7eff"/>
    </Style>
    <!-- Settings button -->
    <Style Selector="Button#SettingsButton materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#4a5668"/>
    </Style>
    <Style Selector="Button#SettingsButton /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button#SettingsButton:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button#SettingsButton:pointerover materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#b0bac6"/>
    </Style>
    <Style Selector="Button#SettingsButton.active materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="White"/>
    </Style>
  </UserControl.Styles>

  <Border BorderBrush="#1e2530" BorderThickness="0">
    <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0,12,0">

      <!-- Left: navigation tabs -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Stretch">
        <Button x:Name="PlayTabButton" Classes="nav-tab" Classes.active="{Binding IsPlayTabActive}" Click="OnPlayTabClicked">
          <Grid RowDefinitions="*,2">
            <TextBlock Grid.Row="0" Classes="nav-label" Text="{x:Static res:Strings.TabGame}"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       LetterSpacing="2"/>
            <Rectangle Grid.Row="1" Classes="nav-indicator"
                       HorizontalAlignment="Stretch"/>
          </Grid>
        </Button>
        <Button x:Name="LiveTabButton" Classes="nav-tab" Classes.active="{Binding IsLiveTabActive}" Click="OnLiveTabClicked">
          <Grid RowDefinitions="*,2">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
              <Ellipse Width="7" Height="7" Fill="#27AE60" VerticalAlignment="Center"
                       IsVisible="{Binding AnyLiveGame}"/>
              <TextBlock Classes="nav-label" Text="LIVE" LetterSpacing="2"/>
            </StackPanel>
            <Rectangle Grid.Row="1" Classes="nav-indicator"
                       HorizontalAlignment="Stretch"/>
          </Grid>
        </Button>
      </StackPanel>

      <!-- Center: game found → connect button; or searching indicator (hidden on Play tab which has its own) -->
      <Panel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
             IsVisible="{Binding !IsPlayTabActive}">

        <!-- Game found: connect button -->
        <Button x:Name="ConnectButton"
                IsVisible="{Binding Launch.HasServerUrl}"
                Click="OnConnectClicked"
                VerticalAlignment="Center"
                Padding="20,6" CornerRadius="2" BorderThickness="0" Cursor="Hand">
          <Button.Styles>
            <Style Selector="Button#ConnectButton">
              <Setter Property="Background">
                <Setter.Value>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1a5aaa" Offset="0"/>
                    <GradientStop Color="#3a90d6" Offset="1"/>
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
            </Style>
            <Style Selector="Button#ConnectButton:pointerover /template/ ContentPresenter">
              <Setter Property="Background">
                <Setter.Value>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2a6aba" Offset="0"/>
                    <GradientStop Color="#4aa0e6" Offset="1"/>
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
            </Style>
          </Button.Styles>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="8" Height="8" Fill="#5dade2" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Static res:Strings.Connect}" Foreground="White"
                       FontSize="{DynamicResource FontSizeBase}" FontWeight="Bold"
                       LetterSpacing="1" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- Searching indicator (only when not game found) -->
        <Border IsVisible="{Binding Queue.IsSearching}"
                Background="#0d2a1a" BorderBrush="#27AE60" BorderThickness="1"
                CornerRadius="0" Padding="12,6">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Ellipse Width="8" Height="8" Fill="#27AE60" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Static res:Strings.SearchingGame}" Foreground="#27AE60"
                       FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Queue.QueueButtonTimeText}"
                       Foreground="#7ab57a" FontSize="{DynamicResource FontSizeBase}"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Border>

      </Panel>

      <!-- Right: launch button + settings gear + user avatar -->
      <StackPanel Grid.Column="2" Orientation="Horizontal">
        <Button x:Name="LaunchGameButton" VerticalAlignment="Center" Margin="0,0,6,0"
                Padding="12,6" CornerRadius="2" Cursor="Hand"
                Click="OnLaunchGameClicked"
                Classes.stop="{Binding Launch.PlayButtonIsStop}"
                BorderThickness="1">
          <Button.Styles>
            <Style Selector="Button#LaunchGameButton">
              <Setter Property="Background" Value="#0d2a1a"/>
              <Setter Property="BorderBrush" Value="#27AE60"/>
            </Style>
            <Style Selector="Button#LaunchGameButton /template/ ContentPresenter">
              <Setter Property="Background" Value="#0d2a1a"/>
            </Style>
            <Style Selector="Button#LaunchGameButton:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="#123520"/>
            </Style>
            <Style Selector="Button#LaunchGameButton materialIcons|MaterialIcon">
              <Setter Property="Foreground" Value="#27AE60"/>
            </Style>
            <Style Selector="Button#LaunchGameButton TextBlock">
              <Setter Property="Foreground" Value="#27AE60"/>
            </Style>
            <!-- Stop state -->
            <Style Selector="Button#LaunchGameButton.stop">
              <Setter Property="Background" Value="#2a0d0d"/>
              <Setter Property="BorderBrush" Value="#c0392b"/>
            </Style>
            <Style Selector="Button#LaunchGameButton.stop /template/ ContentPresenter">
              <Setter Property="Background" Value="#2a0d0d"/>
            </Style>
            <Style Selector="Button#LaunchGameButton.stop:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="#38110f"/>
            </Style>
            <Style Selector="Button#LaunchGameButton.stop materialIcons|MaterialIcon">
              <Setter Property="Foreground" Value="#e74c3c"/>
            </Style>
            <Style Selector="Button#LaunchGameButton.stop TextBlock">
              <Setter Property="Foreground" Value="#e74c3c"/>
            </Style>
          </Button.Styles>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <materialIcons:MaterialIcon Kind="PlayArrow" Width="16" Height="16"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding !Launch.PlayButtonIsStop}"/>
            <materialIcons:MaterialIcon Kind="Stop" Width="14" Height="14"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding Launch.PlayButtonIsStop}"/>
            <TextBlock Text="{x:Static res:Strings.Play}" FontSize="{DynamicResource FontSizeBase}"
                       FontWeight="SemiBold" LetterSpacing="1" VerticalAlignment="Center"
                       IsVisible="{Binding !Launch.PlayButtonIsStop}"/>
            <TextBlock Text="{x:Static res:Strings.Stop}" FontSize="{DynamicResource FontSizeBase}"
                       FontWeight="SemiBold" LetterSpacing="1" VerticalAlignment="Center"
                       IsVisible="{Binding Launch.PlayButtonIsStop}"/>
          </StackPanel>
        </Button>
        <Button x:Name="SettingsButton" VerticalAlignment="Stretch" Padding="10,8"
                Background="Transparent" BorderThickness="0" CornerRadius="0"
                Cursor="Hand" Click="OnSettingsTabClicked"
                Classes.active="{Binding IsSettingsOpen}">
          <materialIcons:MaterialIcon Kind="Cog" Width="20" Height="20"/>
        </Button>
        <Button x:Name="ProfileButton" VerticalAlignment="Stretch" Padding="10,8"
                Background="Transparent" BorderThickness="0" CornerRadius="0"
                Cursor="Hand" Click="OnProfileTabClicked">
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Grid Width="32" Height="32">
              <Border Width="32" Height="32" CornerRadius="0" ClipToBounds="True"
                      Background="#2d3842">
                <Image Source="{Binding AvatarImage}" Width="32" Height="32" Stretch="UniformToFill"/>
              </Border>
              <Ellipse Width="9" Height="9" Fill="#4CAF50"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,-2,-2">
                <Ellipse.Stroke>
                  <SolidColorBrush Color="#1e2530"/>
                </Ellipse.Stroke>
                <Ellipse.StrokeThickness>2</Ellipse.StrokeThickness>
              </Ellipse>
            </Grid>
            <TextBlock Text="{Binding CurrentUser.PersonaName}"
                       FontWeight="SemiBold" FontSize="{DynamicResource FontSizeMD}"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>

    </Grid>
  </Border>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:m="using:d2c_launcher.Models"
             xmlns:util="using:d2c_launcher.Util"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             x:Class="d2c_launcher.Views.Components.GameSearchPanel"
             x:DataType="vm:QueueViewModel">
  <UserControl.Resources>
      <util:InverseBoolConverter x:Key="InverseBoolConverter"/>
  </UserControl.Resources>

  <Border CornerRadius="0" Background="#121315" BorderBrush="#2d3842"
          BorderThickness="1" ClipToBounds="True">
      <StackPanel>
          <!-- Header -->
          <Border Background="#0A0B0D" Padding="12,0" MinHeight="34"
                  BorderBrush="#1e2530" BorderThickness="0,0,0,1">
              <TextBlock Text="ПОИСК ИГРЫ" Foreground="#D9D9D9" FontWeight="SemiBold" FontSize="10"
                         LetterSpacing="2" VerticalAlignment="Center"/>
          </Border>

          <!-- Mode list -->
          <Border IsEnabled="{Binding IsSearching, Converter={StaticResource InverseBoolConverter}}">
              <ItemsControl ItemsSource="{Binding MatchmakingModes}">
                  <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                          <StackPanel/>
                      </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="m:MatchmakingModeView">
                          <Button Command="{Binding ToggleSelectionCommand}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Padding="0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Cursor="Hand">
                          <Border Padding="8,6" BorderBrush="#2d3842" BorderThickness="0,0,0,1">
                              <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                  <CheckBox Grid.Column="0"
                                            IsChecked="{Binding IsSelected}"
                                            IsEnabled="{Binding IsRestricted, Converter={StaticResource InverseBoolConverter}}"
                                            IsHitTestVisible="False"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"/>
                                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                      <!-- Mode name with lock icon when restricted -->
                                      <StackPanel Orientation="Horizontal" Spacing="4">
                                          <materialIcons:MaterialIcon Kind="Lock"
                                                                       Width="12" Height="12"
                                                                       Foreground="#C62626"
                                                                       IsVisible="{Binding IsRestricted}"
                                                                       VerticalAlignment="Center"/>
                                          <TextBlock Text="{Binding Name}"
                                                     FontWeight="SemiBold"
                                                     Foreground="#C8A84B"
                                                     VerticalAlignment="Center"/>
                                      </StackPanel>
                                      <!-- Ban/access restriction reason -->
                                      <TextBlock Text="{Binding RestrictionText}"
                                                 IsVisible="{Binding IsRestricted}"
                                                 Foreground="#C62626" FontSize="11"/>
                                      <!-- Queue count -->
                                      <TextBlock Text="{Binding InQueue, StringFormat={}{0} в поиске}"
                                                 Foreground="#888888" FontSize="11"/>
                                  </StackPanel>
                                  <!-- Stub icons -->
                                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                              VerticalAlignment="Center" Margin="8,0,4,0">
                                      <materialIcons:MaterialIcon Kind="ShieldOutline"
                                                                   Width="16" Height="16"
                                                                   Foreground="#666666"/>
                                      <materialIcons:MaterialIcon Kind="TrophyOutline"
                                                                   Width="16" Height="16"
                                                                   Foreground="#666666"/>
                                  </StackPanel>
                              </Grid>
                          </Border>
                          </Button>
                      </DataTemplate>
                  </ItemsControl.ItemTemplate>
              </ItemsControl>
          </Border>
      </StackPanel>
  </Border>
</UserControl>

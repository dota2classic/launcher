<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:m="using:d2c_launcher.Models"
             xmlns:util="using:d2c_launcher.Util"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             x:Class="d2c_launcher.Views.Components.GameSearchPanel"
             x:DataType="vm:QueueViewModel">
  <UserControl.Resources>
      <util:InverseBoolConverter x:Key="InverseBoolConverter"/>
      <util:BoolToNotAllowedCursorConverter x:Key="BoolToNotAllowedCursorConverter"/>
      <util:BoolToRestrictedOpacityConverter x:Key="BoolToRestrictedOpacityConverter"/>
  </UserControl.Resources>

  <Border CornerRadius="0" Background="#121315" BorderBrush="#2d3842"
          BorderThickness="1" ClipToBounds="True">
      <StackPanel>
          <!-- Header -->
          <Border Background="#0A0B0D" Padding="12,0" MinHeight="34"
                  BorderBrush="#1e2530" BorderThickness="0,0,0,1">
              <Grid>
                  <TextBlock Text="ПОИСК ИГРЫ" Foreground="#D9D9D9" FontWeight="SemiBold" FontSize="{DynamicResource FontSizeXS}"
                             LetterSpacing="2" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding OnlineStatsText}" HorizontalAlignment="Right"
                             Foreground="#888888" FontWeight="Normal" FontSize="{DynamicResource FontSizeXS}"
                             LetterSpacing="1" VerticalAlignment="Center"/>
              </Grid>
          </Border>

          <!-- Mode list -->
          <Border IsEnabled="{Binding IsSearching, Converter={StaticResource InverseBoolConverter}}"
                  Opacity="{Binding IsSearching, Converter={StaticResource BoolToRestrictedOpacityConverter}}">
              <ItemsControl ItemsSource="{Binding MatchmakingModes}">
                  <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                          <StackPanel/>
                      </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="m:MatchmakingModeView">
                          <Button Command="{Binding ToggleSelectionCommand}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Padding="0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Cursor="{Binding IsRestricted, Converter={StaticResource BoolToNotAllowedCursorConverter}}"
                                  ToolTip.Tip="{Binding FlagsTooltip}"
                                  ToolTip.ShowDelay="1000">
                          <Border Padding="8,6" BorderBrush="#2d3842" BorderThickness="0,0,0,1"
                                  Opacity="{Binding IsRestricted, Converter={StaticResource BoolToRestrictedOpacityConverter}}">
                              <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                  <CheckBox Grid.Column="0"
                                            IsChecked="{Binding IsSelected}"
                                            IsEnabled="{Binding IsRestricted, Converter={StaticResource InverseBoolConverter}}"
                                            IsHitTestVisible="False"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"/>
                                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                      <!-- Mode name with lock icon when restricted -->
                                      <StackPanel Orientation="Horizontal" Spacing="4">
                                          <materialIcons:MaterialIcon Kind="Lock"
                                                                       Width="12" Height="12"
                                                                       Foreground="#C62626"
                                                                       IsVisible="{Binding IsRestricted}"
                                                                       VerticalAlignment="Center"/>
                                          <TextBlock Text="{Binding Name}"
                                                     FontWeight="SemiBold"
                                                     Foreground="#C8A84B"
                                                     VerticalAlignment="Center"/>
                                      </StackPanel>
                                      <!-- Ban/access restriction reason -->
                                      <TextBlock Text="{Binding RestrictionText}"
                                                 IsVisible="{Binding IsRestricted}"
                                                 Foreground="#C62626" FontSize="{DynamicResource FontSizeSM}"/>
                                      <!-- Queue count -->
                                      <TextBlock Text="{Binding InQueue, StringFormat={}{0} в поиске}"
                                                 Foreground="#888888" FontSize="{DynamicResource FontSizeSM}"/>
                                  </StackPanel>
                                  <!-- Mode flags -->
                                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                              VerticalAlignment="Center" Margin="8,0,4,0">
                                      <materialIcons:MaterialIcon Kind="ShieldAlert"
                                                                   Width="16" Height="16"
                                                                   Foreground="#8A7030"
                                                                   IsVisible="{Binding PenaltyAbandon}"/>
                                      <materialIcons:MaterialIcon Kind="ExitToApp"
                                                                   Width="16" Height="16"
                                                                   Foreground="#4A7A90"
                                                                   IsVisible="{Binding NoPenaltyAbandon}"/>
                                      <materialIcons:MaterialIcon Kind="TrophyOutline"
                                                                   Width="16" Height="16"
                                                                   Foreground="#8A7030"
                                                                   IsVisible="{Binding HasDrops}"/>
                                      <materialIcons:MaterialIcon Kind="Robot"
                                                                   Width="16" Height="16"
                                                                   Foreground="#4A7A90"
                                                                   IsVisible="{Binding FillBots}"/>
                                  </StackPanel>
                              </Grid>
                          </Border>
                          </Button>
                      </DataTemplate>
                  </ItemsControl.ItemTemplate>
              </ItemsControl>
          </Border>
      </StackPanel>
  </Border>
</UserControl>

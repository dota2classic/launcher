<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:d2c_launcher.ViewModels"
            xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
            xmlns:components="using:d2c_launcher.Views.Components"
            xmlns:res="clr-namespace:d2c_launcher.Resources"
            x:Class="d2c_launcher.Views.Components.NotificationArea"
            x:DataType="vm:NotificationAreaViewModel">

   <ItemsControl ItemsSource="{Binding Notifications}">
       <ItemsControl.DataTemplates>

           <!-- Party invite toast -->
           <DataTemplate DataType="vm:PartyInviteNotificationViewModel">
               <Border Classes="ToastShell" Classes.closing="{Binding IsClosing}">
                   <Grid RowDefinitions="Auto,3">

                       <StackPanel Grid.Row="0" Spacing="12" Margin="14">

                           <!-- Inviter info + close -->
                           <Grid ColumnDefinitions="Auto,*,Auto">
                               <Border Grid.Column="0"
                                       Width="42" Height="42"
                                       ClipToBounds="True"
                                       Background="#242c34">
                                   <Image Stretch="UniformToFill"
                                          asyncImageLoader:ImageLoader.Source="{Binding InviterAvatarUrl}"/>
                               </Border>
                               <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                   <TextBlock Text="{Binding InviterName}"
                                              FontWeight="SemiBold" Foreground="#4DA9F3"
                                              TextTrimming="CharacterEllipsis"/>
                                   <TextBlock Text="{x:Static res:Strings.InvitesToParty}"
                                              FontSize="{DynamicResource FontSizeSM}" Foreground="#AAAAAA"/>
                               </StackPanel>
                               <Button Grid.Column="2"
                                       Content="✕"
                                       Command="{Binding DismissCommand}"
                                       Background="Transparent" Foreground="#535252"
                                       FontSize="{DynamicResource FontSizeSM}"
                                       BorderThickness="0" Padding="0"
                                       VerticalAlignment="Top" HorizontalAlignment="Right"
                                       Cursor="Hand"/>
                           </Grid>

                           <!-- Accept / Decline -->
                           <Grid ColumnDefinitions="*,6,*">
                               <Button Grid.Column="0"
                                       Content="{x:Static res:Strings.AcceptUpper}"
                                       Command="{Binding AcceptCommand}"
                                       Background="#1a5aaa" Foreground="White"
                                       FontSize="{DynamicResource FontSizeBase}" FontWeight="Bold"
                                       CornerRadius="0" BorderThickness="0"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       Padding="0,8"/>
                               <Button Grid.Column="2"
                                       Content="{x:Static res:Strings.DeclineUpper}"
                                       Command="{Binding DeclineCommand}"
                                       Background="#6e2222" Foreground="White"
                                       FontSize="{DynamicResource FontSizeBase}" FontWeight="Bold"
                                       CornerRadius="0" BorderThickness="0"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       Padding="0,8"/>
                           </Grid>

                       </StackPanel>

                       <!-- Duration bar -->
                       <components:ToastTimerBar Grid.Row="1"/>

                   </Grid>
               </Border>
           </DataTemplate>

           <!-- Invite sent toast -->
           <DataTemplate DataType="vm:InviteSentToastViewModel">
               <Border Classes="ToastShell" Classes.closing="{Binding IsClosing}">
                   <Grid RowDefinitions="Auto,3">

                       <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="14">
                           <!-- Avatar -->
                           <Border Grid.Column="0"
                                   Width="36" Height="36"
                                   ClipToBounds="True"
                                   Background="#242c34">
                               <Image Stretch="UniformToFill"
                                      asyncImageLoader:ImageLoader.Source="{Binding AvatarUrl}"/>
                           </Border>
                           <!-- Name + label -->
                           <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                               <TextBlock Text="{Binding PlayerName}"
                                          FontWeight="SemiBold" Foreground="#4DA9F3"
                                          TextTrimming="CharacterEllipsis"/>
                               <TextBlock Text="{x:Static res:Strings.InvitedToYourParty}"
                                          FontSize="{DynamicResource FontSizeSM}" Foreground="#AAAAAA"/>
                           </StackPanel>
                           <!-- Dismiss -->
                           <Button Grid.Column="2"
                                   Content="✕"
                                   Command="{Binding DismissCommand}"
                                   Background="Transparent" Foreground="#535252"
                                   FontSize="{DynamicResource FontSizeSM}"
                                   BorderThickness="0" Padding="0" Margin="10,0,0,0"
                                   VerticalAlignment="Top" HorizontalAlignment="Right"
                                   Cursor="Hand"/>
                       </Grid>

                       <!-- Duration bar -->
                       <components:ToastTimerBar Grid.Row="1"/>

                   </Grid>
               </Border>
           </DataTemplate>

           <!-- Corrupted files toast (dota.exe missing) -->
           <DataTemplate DataType="vm:CorruptedFilesToastViewModel">
               <Border Classes="ToastShell" Classes.closing="{Binding IsClosing}">
                   <Grid RowDefinitions="Auto,3">

                       <StackPanel Grid.Row="0" Spacing="10" Margin="14">

                           <Grid ColumnDefinitions="*,Auto">
                               <TextBlock Grid.Column="0"
                                          Text="{Binding Message}"
                                          Foreground="#DDDDDD"
                                          FontSize="{DynamicResource FontSizeSM}"
                                          TextWrapping="Wrap"
                                          VerticalAlignment="Center"/>
                               <Button Grid.Column="1"
                                       Content="✕"
                                       Command="{Binding DismissCommand}"
                                       Background="Transparent" Foreground="#535252"
                                       FontSize="{DynamicResource FontSizeSM}"
                                       BorderThickness="0" Padding="0" Margin="10,0,0,0"
                                       VerticalAlignment="Top" HorizontalAlignment="Right"
                                       Cursor="Hand"/>
                           </Grid>

                           <Button Content="{x:Static res:Strings.VerifyIntegrity}"
                                   Command="{Binding VerifyCommand}"
                                   Background="#1a5aaa" Foreground="White"
                                   FontSize="{DynamicResource FontSizeBase}" FontWeight="Bold"
                                   CornerRadius="0" BorderThickness="0"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Center"
                                   Padding="0,8"
                                   Cursor="Hand"/>

                       </StackPanel>

                       <!-- Duration bar -->
                       <components:ToastTimerBar Grid.Row="1"/>

                   </Grid>
               </Border>
           </DataTemplate>

           <!-- GO_QUEUE toast (titled) -->
           <DataTemplate DataType="vm:GoQueueToastViewModel">
               <Border Classes="ToastShell" Classes.closing="{Binding IsClosing}">
                   <Grid RowDefinitions="Auto,3">
                       <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="14,10,14,10">
                           <StackPanel Grid.Column="0" Spacing="3">
                               <TextBlock Text="{Binding Title}"
                                          Foreground="#FFFFFF"
                                          FontSize="{DynamicResource FontSizeSM}"
                                          FontWeight="SemiBold"
                                          TextWrapping="Wrap"/>
                               <TextBlock Text="{Binding Content}"
                                          Foreground="#BBBBBB"
                                          FontSize="{DynamicResource FontSizeXS}"
                                          TextWrapping="Wrap"/>
                           </StackPanel>
                           <Button Grid.Column="1"
                                   Content="✕"
                                   Command="{Binding DismissCommand}"
                                   Background="Transparent" Foreground="#535252"
                                   FontSize="{DynamicResource FontSizeSM}"
                                   BorderThickness="0" Padding="0" Margin="10,0,0,0"
                                   VerticalAlignment="Top" HorizontalAlignment="Right"
                                   Cursor="Hand"/>
                       </Grid>
                       <components:ToastTimerBar Grid.Row="1"/>
                   </Grid>
               </Border>
           </DataTemplate>

           <!-- Achievement unlocked toast -->
           <DataTemplate DataType="vm:AchievementToastViewModel">
               <Border Classes="ToastShell" Classes.closing="{Binding IsClosing}">
                   <Grid RowDefinitions="Auto,3">

                       <StackPanel Grid.Row="0" Spacing="10" Margin="14,10,14,10">

                           <!-- Header: icon + title + dismiss -->
                           <Grid ColumnDefinitions="Auto,*,Auto">
                               <!-- Achievement image -->
                               <Border Grid.Column="0"
                                       Width="48" Height="48"
                                       ClipToBounds="True"
                                       Background="#242c34"
                                       IsVisible="{Binding ImageUrl, Converter={x:Static ObjectConverters.IsNotNull}}">
                                   <Image Stretch="UniformToFill"
                                          asyncImageLoader:ImageLoader.Source="{Binding ImageUrl}"/>
                               </Border>
                               <!-- Title + label -->
                               <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                   <TextBlock Text="{x:Static res:Strings.AchievementUnlocked}"
                                              FontSize="{DynamicResource FontSizeXS}"
                                              Foreground="#AAAAAA"/>
                                   <TextBlock Text="{Binding Title}"
                                              FontWeight="SemiBold"
                                              Foreground="#F5C543"
                                              TextTrimming="CharacterEllipsis"/>
                               </StackPanel>
                               <!-- Dismiss -->
                               <Button Grid.Column="2"
                                       Content="✕"
                                       Command="{Binding DismissCommand}"
                                       Background="Transparent" Foreground="#535252"
                                       FontSize="{DynamicResource FontSizeSM}"
                                       BorderThickness="0" Padding="0" Margin="10,0,0,0"
                                       VerticalAlignment="Top" HorizontalAlignment="Right"
                                       Cursor="Hand"/>
                           </Grid>

                           <!-- Description -->
                           <TextBlock Text="{Binding Description}"
                                      Foreground="#CCCCCC"
                                      FontSize="{DynamicResource FontSizeXS}"
                                      TextWrapping="Wrap"/>

                           <!-- Open achievements page -->
                           <Button Content="{x:Static res:Strings.OpenAchievements}"
                                   Command="{Binding OpenCommand}"
                                   Background="#1a5aaa" Foreground="White"
                                   FontSize="{DynamicResource FontSizeBase}" FontWeight="Bold"
                                   CornerRadius="0" BorderThickness="0"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Center"
                                   Padding="0,8"
                                   Cursor="Hand"/>

                       </StackPanel>

                       <!-- Duration bar -->
                       <components:ToastTimerBar Grid.Row="1"/>

                   </Grid>
               </Border>
           </DataTemplate>

           <!-- Simple text toast -->
           <DataTemplate DataType="vm:SimpleToastViewModel">
               <Border Classes="ToastShell" Classes.closing="{Binding IsClosing}">
                   <Grid RowDefinitions="Auto,3">

                       <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="14">
                           <TextBlock Grid.Column="0"
                                      Text="{Binding Message}"
                                      Foreground="#DDDDDD"
                                      FontSize="{DynamicResource FontSizeSM}"
                                      TextWrapping="Wrap"
                                      VerticalAlignment="Center"/>
                           <Button Grid.Column="1"
                                   Content="✕"
                                   Command="{Binding DismissCommand}"
                                   Background="Transparent" Foreground="#535252"
                                   FontSize="{DynamicResource FontSizeSM}"
                                   BorderThickness="0" Padding="0" Margin="10,0,0,0"
                                   VerticalAlignment="Top" HorizontalAlignment="Right"
                                   Cursor="Hand"/>
                       </Grid>

                       <!-- Duration bar -->
                       <components:ToastTimerBar Grid.Row="1"/>

                   </Grid>
               </Border>
           </DataTemplate>

       </ItemsControl.DataTemplates>
   </ItemsControl>

</UserControl>

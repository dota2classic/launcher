<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:components="using:d2c_launcher.Views.Components"
             xmlns:res="clr-namespace:d2c_launcher.Resources"
             x:Class="d2c_launcher.Views.Components.LivePanel"
             x:DataType="vm:LiveViewModel">

    <Border Classes="Block" ClipToBounds="True">
        <Grid ColumnDefinitions="350,*">

            <!-- ── Sidebar: match list ─────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="#0A0C0F"
                    BorderBrush="#252E3A" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">

                    <!-- Header -->
                    <Border Grid.Row="0" Classes="BlockHead">
                        <TextBlock Classes="BlockTitle" Text="{x:Static res:Strings.Broadcasts}"/>
                    </Border>

                    <!-- States -->
                    <TextBlock Grid.Row="1" Text="{x:Static res:Strings.LoadingEllipsis}"
                               Foreground="#888888" FontSize="{DynamicResource FontSizeSM}"
                               IsVisible="{Binding IsLoading}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Text="{x:Static res:Strings.NoActiveGames}"
                               Foreground="#888888" FontSize="{DynamicResource FontSizeSM}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasNoMatches}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <!-- Match list -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Matches}"
                             SelectedItem="{Binding SelectedMatch}"
                             Background="Transparent" BorderThickness="0" Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             IsVisible="{Binding !HasNoMatches}">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="#0d1520"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#0a1018"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:LiveMatchCardViewModel">
                                <Grid ColumnDefinitions="3,*">
                                    <!-- Selected accent bar -->
                                    <Border Grid.Column="0" Width="3" Background="#3a7abd"
                                            IsVisible="{Binding $parent[ListBoxItem].IsSelected}"/>

                                    <!-- Card content -->
                                    <Grid Grid.Column="1" ColumnDefinitions="140,*"
                                          Height="140"
                                          Margin="0,0,0,1">

                                        <!-- Small minimap -->
                                        <Viewbox Grid.Column="0" Width="140" Height="140" Stretch="Uniform">
                                            <components:MinimapPanel ItemsSource="{Binding Heroes}"
                                                                      BuildingsSource="{Binding Buildings}"
                                                                      UseSmallIcons="True"/>
                                        </Viewbox>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" Spacing="6" Margin="10,10,8,10"
                                                    VerticalAlignment="Center">
                                            <!-- Score -->
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding RadiantScore}"
                                                           FontSize="{DynamicResource FontSize2XL5}" FontWeight="Bold"
                                                           Foreground="#6db442"/>
                                                <TextBlock Text="—"
                                                           FontSize="{DynamicResource FontSizeXL}" Foreground="#2e3e4e"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DireScore}"
                                                           FontSize="{DynamicResource FontSize2XL5}" FontWeight="Bold"
                                                           Foreground="#c83c2c"/>
                                            </StackPanel>
                                            <!-- Mode -->
                                            <TextBlock Text="{Binding ModeLabel}"
                                                       FontSize="{DynamicResource FontSizeSM}" Foreground="#7a9ab0"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <!-- Duration -->
                                            <TextBlock Text="{Binding Duration}"
                                                       FontSize="{DynamicResource FontSizeSM}" FontWeight="SemiBold"
                                                       Foreground="#8899aa"/>
                                            <!-- State dot + label -->
                                            <StackPanel Orientation="Horizontal" Spacing="5"
                                                        VerticalAlignment="Center">
                                                <Ellipse Width="6" Height="6"
                                                         Fill="#3a9a3a" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding GameStateLabel}"
                                                           FontSize="{DynamicResource FontSizeXS}" Foreground="#4a7060"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ── Match detail ───────────────────────────────────── -->
            <Grid Grid.Column="1">

                <!-- No match selected -->
                <TextBlock Text="{x:Static res:Strings.NoActiveGames}"
                           Foreground="#888888"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="{DynamicResource FontSizeMD}"
                           IsVisible="{Binding SelectedMatch, Converter={x:Static ObjectConverters.IsNull}}"/>

                <!-- Match selected -->
                <Grid RowDefinitions="Auto,*"
                      IsVisible="{Binding SelectedMatch, Converter={x:Static ObjectConverters.IsNotNull}}">

                    <!-- ── Detail header ──────────────────────────── -->
                    <Border Grid.Row="0"
                            Background="#0A0C0F"
                            BorderBrush="#252E3A" BorderThickness="0,0,0,1"
                            Padding="20,12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{x:Static res:Strings.GameMode}"
                                           FontSize="{DynamicResource FontSize2XS}" FontWeight="Bold" LetterSpacing="2"
                                           Foreground="#888888"/>
                                <TextBlock Text="{Binding SelectedMatch.ModeLabel}"
                                           FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold"
                                           Foreground="#d8e8f4"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Orientation="Horizontal">
                                <Button Content="{x:Static res:Strings.Watch}"
                                        Command="{Binding $parent[UserControl].((vm:LiveViewModel)DataContext).SpectateSelectedMatchCommand}"
                                        Classes="PrimaryButton"
                                        Padding="14,8"
                                        FontSize="{DynamicResource FontSizeSM}"
                                        CornerRadius="3"
                                        Cursor="Hand"/>
                                <Border Width="1" Background="#252E3A" Margin="4,4"/>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{x:Static res:Strings.ColScore}"
                                               FontSize="{DynamicResource FontSize2XS}" FontWeight="Bold" LetterSpacing="2"
                                               Foreground="#888888" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedMatch.RadiantScore}"
                                                   FontSize="{DynamicResource FontSize2XL5}" FontWeight="Bold" Foreground="#6db442"/>
                                        <TextBlock Text="—" FontSize="{DynamicResource FontSize2XL}" Foreground="#4a5a6a" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedMatch.DireScore}"
                                                   FontSize="{DynamicResource FontSize2XL5}" FontWeight="Bold" Foreground="#c83c2c"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Width="1" Background="#252E3A" Margin="12,4"/>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{x:Static res:Strings.ColTime}"
                                               FontSize="{DynamicResource FontSize2XS}" FontWeight="Bold" LetterSpacing="2"
                                               Foreground="#888888" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedMatch.Duration}"
                                               FontSize="{DynamicResource FontSize2XL5}" FontWeight="Bold"
                                               Foreground="#8899aa" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Players + minimap ─────────────────────── -->
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <Grid ColumnDefinitions="Auto,Auto,Auto" Margin="12,12" VerticalAlignment="Stretch" HorizontalAlignment="Center">

                            <!-- ── Radiant ──────────────────────────── -->
                            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                                    <TextBlock Grid.Column="0"
                                               Text="RADIANT"
                                               FontSize="{DynamicResource FontSize2XS}" FontWeight="Bold" LetterSpacing="2"
                                               Foreground="#6db442" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedMatch.RadiantScore}"
                                               FontSize="{DynamicResource FontSizeXL}" FontWeight="Bold"
                                               Foreground="#6db442"/>
                                </Grid>
                                <ItemsControl Grid.Row="1" VerticalAlignment="Top"
                                              ItemsSource="{Binding SelectedMatch.RadiantPlayers}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="5"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LivePlayerRowViewModel">
                                            <components:LivePlayerRowView MirrorLayout="False"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- ── Minimap ──────────────────────────── -->
                            <Viewbox Grid.Column="1" Margin="12,28,12,0"
                                     VerticalAlignment="Top" Stretch="Uniform" MaxHeight="364">
                                <components:MinimapPanel ItemsSource="{Binding SelectedMatch.Heroes}"
                                                          BuildingsSource="{Binding SelectedMatch.Buildings}"
                                                          UseSmallIcons="False"/>
                            </Viewbox>

                            <!-- ── Dire ────────────────────────────── -->
                            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SelectedMatch.DireScore}"
                                               FontSize="{DynamicResource FontSizeXL}" FontWeight="Bold"
                                               Foreground="#c83c2c"/>
                                    <TextBlock Grid.Column="1"
                                               Text="DIRE"
                                               FontSize="{DynamicResource FontSize2XS}" FontWeight="Bold" LetterSpacing="2"
                                               Foreground="#c83c2c"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <ItemsControl Grid.Row="1" VerticalAlignment="Top"
                                              ItemsSource="{Binding SelectedMatch.DirePlayers}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="5"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LivePlayerRowViewModel">
                                            <components:LivePlayerRowView MirrorLayout="True"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>

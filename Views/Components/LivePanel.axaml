<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:util="using:d2c_launcher.Util"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:components="using:d2c_launcher.Views.Components"
             x:Class="d2c_launcher.Views.Components.LivePanel"
             x:DataType="vm:LiveViewModel">

    <UserControl.Resources>
        <util:TeamColorConverter x:Key="TeamColorConverter"/>
    </UserControl.Resources>

    <Grid ColumnDefinitions="280,*">

        <!-- ── Sidebar: match list ─────────────────────────────── -->
        <Border Grid.Column="0"
                Background="#060a0f"
                BorderBrush="#111820" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">

                <!-- Header -->
                <Border Grid.Row="0" Padding="10,10,10,8"
                        BorderBrush="#111820" BorderThickness="0,0,0,1">
                    <TextBlock Text="ТРАНСЛЯЦИИ"
                               FontSize="10" FontWeight="Bold" LetterSpacing="2"
                               Foreground="#4a6070"/>
                </Border>

                <!-- States -->
                <TextBlock Grid.Row="1" Text="Загрузка…"
                           Foreground="#3a4a5a" FontSize="{DynamicResource FontSizeSM}"
                           IsVisible="{Binding IsLoading}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="1" Text="Нет активных игр"
                           Foreground="#3a4a5a" FontSize="{DynamicResource FontSizeSM}"
                           TextWrapping="Wrap"
                           IsVisible="{Binding HasNoMatches}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Match list -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Matches}"
                         SelectedItem="{Binding SelectedMatch}"
                         Background="Transparent" BorderThickness="0" Padding="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         IsVisible="{Binding !HasNoMatches}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0d1520"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0a1018"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LiveMatchCardViewModel">
                            <Grid ColumnDefinitions="3,*">
                                <!-- Selected accent bar -->
                                <Border Grid.Column="0" Width="3" Background="#3a7abd"
                                        IsVisible="{Binding $parent[ListBoxItem].IsSelected}"/>

                                <!-- Card content -->
                                <Grid Grid.Column="1" ColumnDefinitions="140,*"
                                      Height="140"
                                      Margin="0,0,0,1">

                                    <!-- Small minimap -->
                                    <Viewbox Grid.Column="0" Width="140" Height="140" Stretch="Uniform">
                                    <Panel Width="320" Height="320" ClipToBounds="True">
                                        <asyncImageLoader:AdvancedImage
                                            Source="https://dotaclassic.ru/minimap.webp"
                                            Width="320" Height="320" Stretch="Fill"/>
                                        <ItemsControl ItemsSource="{Binding Heroes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Panel Width="320" Height="320" IsHitTestVisible="False"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:HeroOnMapViewModel">
                                                    <!-- HeroOnMapViewModel.SmallHeroIconSize = HeroIconSize * CanvasSize / SmallDisplaySize = 64 -->
                                                    <Border Width="64" Height="64"
                                                            HorizontalAlignment="Left" VerticalAlignment="Top"
                                                            Margin="{Binding HeroMargin}">
                                                        <Border.Transitions>
                                                            <Transitions>
                                                                <ThicknessTransition Property="Margin"
                                                                                      Duration="0:0:1"
                                                                                      Easing="CubicEaseInOut"/>
                                                            </Transitions>
                                                        </Border.Transitions>
                                                        <asyncImageLoader:AdvancedImage
                                                            Source="{Binding HeroImageUrl}"
                                                            Stretch="UniformToFill">
                                                            <asyncImageLoader:AdvancedImage.Effect>
                                                                <DropShadowEffect BlurRadius="1" OffsetX="0" OffsetY="0"
                                                                                  Color="{Binding Team, Converter={StaticResource TeamColorConverter}}"/>
                                                            </asyncImageLoader:AdvancedImage.Effect>
                                                        </asyncImageLoader:AdvancedImage>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- Duration badge -->
                                        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                Background="#cc000000" Padding="4,2" Margin="0">
                                            <TextBlock Text="{Binding Duration}"
                                                       FontSize="9" Foreground="#c0d0e0"/>
                                        </Border>
                                    </Panel>
                                    </Viewbox>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Spacing="4" Margin="8,8,8,8"
                                                VerticalAlignment="Center">
                                        <!-- Mode -->
                                        <TextBlock Text="{Binding ModeLabel}"
                                                   FontSize="9" Foreground="#5a7a8a"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- Score -->
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="{Binding RadiantScore}"
                                                       FontSize="16" FontWeight="Bold"
                                                       Foreground="#6db442"/>
                                            <TextBlock Text="-"
                                                       FontSize="14" Foreground="#4a5a6a"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding DireScore}"
                                                       FontSize="16" FontWeight="Bold"
                                                       Foreground="#c83c2c"/>
                                        </StackPanel>
                                        <!-- State -->
                                        <TextBlock Text="{Binding GameStateLabel}"
                                                   FontSize="9" Foreground="#4a6070"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ── Match detail ───────────────────────────────────── -->
        <Grid Grid.Column="1">

            <!-- No match selected -->
            <TextBlock Text="Нет активных игр"
                       Foreground="#3a4a5a"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="{DynamicResource FontSizeMD}"
                       IsVisible="{Binding SelectedMatch, Converter={x:Static ObjectConverters.IsNull}}"/>

            <!-- Match selected -->
            <Grid RowDefinitions="Auto,*"
                  IsVisible="{Binding SelectedMatch, Converter={x:Static ObjectConverters.IsNotNull}}">

                <!-- ── Detail header ──────────────────────────── -->
                <Border Grid.Row="0"
                        Background="#060a0f"
                        BorderBrush="#111820" BorderThickness="0,0,0,1"
                        Padding="20,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="РЕЖИМ ИГРЫ"
                                       FontSize="9" FontWeight="Bold" LetterSpacing="2"
                                       Foreground="#4a6070"/>
                            <TextBlock Text="{Binding SelectedMatch.ModeLabel}"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="#d8e8f4"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Orientation="Horizontal">
                            <StackPanel Spacing="2">
                                <TextBlock Text="СЧЁТ"
                                           FontSize="9" FontWeight="Bold" LetterSpacing="2"
                                           Foreground="#4a6070" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedMatch.RadiantScore}"
                                               FontSize="20" FontWeight="Bold" Foreground="#6db442"/>
                                    <TextBlock Text="—" FontSize="18" Foreground="#4a5a6a" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedMatch.DireScore}"
                                               FontSize="20" FontWeight="Bold" Foreground="#c83c2c"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Width="1" Background="#1a2a3a" Margin="12,4"/>
                            <StackPanel Spacing="2">
                                <TextBlock Text="ВРЕМЯ"
                                           FontSize="9" FontWeight="Bold" LetterSpacing="2"
                                           Foreground="#4a6070" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedMatch.Duration}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#8899aa" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Players + minimap ─────────────────────── -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <Grid ColumnDefinitions="Auto,Auto,Auto" Margin="12,12" VerticalAlignment="Stretch" HorizontalAlignment="Center">

                        <!-- ── Radiant ──────────────────────────── -->
                        <Grid Grid.Column="0" RowDefinitions="Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                                <TextBlock Grid.Column="0"
                                           Text="RADIANT"
                                           FontSize="9" FontWeight="Bold" LetterSpacing="2"
                                           Foreground="#6db442" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectedMatch.RadiantScore}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="#6db442"/>
                            </Grid>
                            <ItemsControl Grid.Row="1" VerticalAlignment="Top"
                                          ItemsSource="{Binding SelectedMatch.RadiantPlayers}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="5"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LivePlayerRowViewModel">
                                        <Border Background="#0a0e14" Margin="0,1" Padding="6,5">
                                            <Grid RowDefinitions="Auto,5,Auto">
                                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                                                    <Panel Grid.Column="0" Width="57" Height="32" Margin="0,0,8,0"
                                                           ClipToBounds="True">
                                                        <asyncImageLoader:AdvancedImage
                                                            Source="{Binding HeroImageUrl}"
                                                            Width="57" Height="32" Stretch="UniformToFill"/>
                                                        <Border Background="#dd000000"
                                                                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                                Padding="2,0">
                                                            <TextBlock Text="{Binding Level}"
                                                                       FontSize="8" FontWeight="Bold"
                                                                       Foreground="#d0e0f0"/>
                                                        </Border>
                                                    </Panel>
                                                    <TextBlock Grid.Column="1"
                                                                   Text="{Binding Name}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#d8e8f4"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding KdaText}"
                                                                   FontSize="9" Foreground="#8899aa"
                                                                   HorizontalAlignment="Right"/>
                                                        <components:KdaBar Kills="{Binding KillsD}"
                                                                            Deaths="{Binding DeathsD}"
                                                                            Assists="{Binding AssistsD}"
                                                                            Height="3" Width="50"/>
                                                    </StackPanel>
                                                </Grid>
                                                <components:DotaItemRow Grid.Row="2"
                                                                         ItemUrls="{Binding ItemUrls}"
                                                                         ItemWidth="34" ItemHeight="24"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- ── Minimap ──────────────────────────── -->
                        <Viewbox Grid.Column="1" Margin="12,28,12,0"
                                 VerticalAlignment="Top" Stretch="Uniform" MaxHeight="364">
                        <Panel Width="320" Height="320">
                            <asyncImageLoader:AdvancedImage
                                Source="https://dotaclassic.ru/minimap.webp"
                                Width="320" Height="320" Stretch="Fill"/>
                            <ItemsControl ItemsSource="{Binding SelectedMatch.Heroes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Panel Width="320" Height="320" IsHitTestVisible="False"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:HeroOnMapViewModel">
                                        <Border Width="28" Height="28"
                                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Margin="{Binding HeroMargin}">
                                            <Border.Transitions>
                                                <Transitions>
                                                    <ThicknessTransition Property="Margin"
                                                                          Duration="0:0:1"
                                                                          Easing="CubicEaseInOut"/>
                                                </Transitions>
                                            </Border.Transitions>
                                            <asyncImageLoader:AdvancedImage
                                                Source="{Binding HeroImageUrl}"
                                                Stretch="UniformToFill">
                                                <asyncImageLoader:AdvancedImage.Effect>
                                                    <DropShadowEffect BlurRadius="2" OffsetX="0" OffsetY="0"
                                                                      Color="{Binding Team, Converter={StaticResource TeamColorConverter}}"/>
                                                </asyncImageLoader:AdvancedImage.Effect>
                                            </asyncImageLoader:AdvancedImage>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Panel>
                        </Viewbox>

                        <!-- ── Dire ────────────────────────────── -->
                        <Grid Grid.Column="2" RowDefinitions="Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding SelectedMatch.DireScore}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="#c83c2c"/>
                                <TextBlock Grid.Column="1"
                                           Text="DIRE"
                                           FontSize="9" FontWeight="Bold" LetterSpacing="2"
                                           Foreground="#c83c2c"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl Grid.Row="1" VerticalAlignment="Top"
                                          ItemsSource="{Binding SelectedMatch.DirePlayers}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="5"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LivePlayerRowViewModel">
                                        <Border Background="#0a0e14" Margin="0,1" Padding="6,5">
                                            <Grid RowDefinitions="Auto,5,Auto">
                                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center"
                                                                HorizontalAlignment="Left" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding KdaText}"
                                                                   FontSize="9" Foreground="#8899aa"
                                                                   HorizontalAlignment="Left"/>
                                                        <components:KdaBar Kills="{Binding KillsD}"
                                                                            Deaths="{Binding DeathsD}"
                                                                            Assists="{Binding AssistsD}"
                                                                            Height="3" Width="50"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#d8e8f4"
                                                               TextTrimming="CharacterEllipsis"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"/>
                                                    <Panel Grid.Column="2" Width="57" Height="32" Margin="8,0,0,0"
                                                           ClipToBounds="True">
                                                        <asyncImageLoader:AdvancedImage
                                                            Source="{Binding HeroImageUrl}"
                                                            Width="57" Height="32" Stretch="UniformToFill"/>
                                                        <Border Background="#dd000000"
                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                Padding="2,0">
                                                            <TextBlock Text="{Binding Level}"
                                                                       FontSize="8" FontWeight="Bold"
                                                                       Foreground="#d0e0f0"/>
                                                        </Border>
                                                    </Panel>
                                                </Grid>
                                                <components:DotaItemRow Grid.Row="2"
                                                                         ItemUrls="{Binding ItemUrls}"
                                                                         ItemWidth="34" ItemHeight="24"
                                                                         HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

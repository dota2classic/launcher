<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:m="using:d2c_launcher.Models"
             xmlns:util="using:d2c_launcher.Util"
             xmlns:components="using:d2c_launcher.Views.Components"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="d2c_launcher.Views.Components.ChatPanel"
             x:DataType="vm:ChatViewModel">


    <Border Background="#0e1012" BorderBrush="#1e2530" BorderThickness="1">
        <Grid RowDefinitions="34,*,Auto">

            <!-- Header -->
            <Border Grid.Row="0" Background="#0a0d10"
                    BorderBrush="#1e2530" BorderThickness="0,0,0,1"
                    Padding="14,0">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="ЧАТ"
                               FontSize="10" FontWeight="SemiBold" LetterSpacing="2"
                               Foreground="#48525a" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Messages -->
            <ScrollViewer Grid.Row="1" x:Name="MessagesScroll"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Panel>
                    <!-- Loading placeholder -->
                    <TextBlock Text="Загрузка..."
                               IsVisible="{Binding IsLoading}"
                               Foreground="#48525a" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,20"/>

                    <!-- Message list -->
                    <ItemsControl ItemsSource="{Binding Messages}"
                                  IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:ChatMessageView">
                                <Border Padding="14,2" Margin="{Binding GroupMargin}">
                                    <Grid ColumnDefinitions="30,10,*">

                                        <!-- Avatar (header only) -->
                                        <Panel Grid.Column="0"
                                               Width="30" Height="30"
                                               VerticalAlignment="Top"
                                               IsVisible="{Binding ShowHeader}">
                                            <!-- Fallback initials circle -->
                                            <Border Width="30" Height="30" CornerRadius="15"
                                                    Background="#1e2a3a"
                                                    BorderBrush="#2d3842" BorderThickness="1">
                                                <TextBlock Text="{Binding Initials}"
                                                           FontSize="10" Foreground="#3a90d6"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- Actual avatar (overlays initials while loading) -->
                                            <Border Width="30" Height="30" CornerRadius="15"
                                                    ClipToBounds="True">
                                                <Image Stretch="UniformToFill"
                                                       asyncImageLoader:ImageLoader.Source="{Binding AvatarUrl}"/>
                                            </Border>
                                        </Panel>

                                        <!-- Body -->
                                        <StackPanel Grid.Column="2" Spacing="2">
                                            <!-- Name + time (header only) -->
                                            <Grid ColumnDefinitions="*,Auto"
                                                  IsVisible="{Binding ShowHeader}">
                                                <TextBlock Text="{Binding AuthorName}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#d9dde0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding TimeText}"
                                                           FontSize="10" Foreground="#48525a"
                                                           VerticalAlignment="Bottom"
                                                           Margin="8,0,0,0"/>
                                            </Grid>
                                            <!-- Message text (rich: emoticons, rarity tags, URLs) -->
                                            <components:RichMessageBlock
                                                Segments="{Binding RichContent}"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Panel>
            </ScrollViewer>

            <!-- Input -->
            <Border Grid.Row="2"
                    BorderBrush="#1e2530" BorderThickness="0,1,0,0"
                    Padding="10,8">
                <Border Background="#1a1d23"
                        CornerRadius="6"
                        Padding="10,0,4,0">
                    <Grid ColumnDefinitions="*,Auto,Auto" MinHeight="34">

                        <TextBox Grid.Column="0"
                                 x:Name="MessageInput"
                                 Text="{Binding InputText}"
                                 Watermark="Введите сообщение"
                                 FontSize="13"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 FocusAdorner="{x:Null}"
                                 VerticalAlignment="Center"
                                 KeyDown="OnInputKeyDown">
                            <TextBox.Styles>
                                <Style Selector="TextBox /template/ Border#PART_BorderElement">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                                <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                                <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </TextBox.Styles>
                        </TextBox>

                        <!-- Emoji button -->
                        <Button Grid.Column="1"
                                Width="30" Height="30"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                VerticalAlignment="Center">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </Button.Styles>
                            <materialIcons:MaterialIcon Kind="EmoticonHappyOutline"
                                                        Width="18" Height="18"
                                                        Foreground="#48525a"/>
                        </Button>

                        <!-- Send button -->
                        <Button Grid.Column="2"
                                Command="{Binding SendMessageCommand}"
                                IsEnabled="{Binding IsSending, Converter={x:Static BoolConverters.Not}}"
                                Width="30" Height="30"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                VerticalAlignment="Center">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </Button.Styles>
                            <materialIcons:MaterialIcon Kind="Send"
                                                        Width="18" Height="18"
                                                        Foreground="#48525a"/>
                        </Button>

                    </Grid>
                </Border>
            </Border>

        </Grid>
    </Border>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="d2c_launcher.Views.Components.DotaItemIcon">

    <!-- Empty slot: dark rectangle. Filled slot: item image. -->
    <Panel Width="{Binding $parent[UserControl].Width}"
           Height="{Binding $parent[UserControl].Height}">

        <!-- Empty slot background (always visible, covered by image when loaded) -->
        <Border Background="#0d1117"
                BorderBrush="#1e2530"
                BorderThickness="1"
                CornerRadius="2"/>

        <!-- Item image (hidden when Source is null/empty) -->
        <asyncImageLoader:AdvancedImage x:Name="ItemImage"
                                        Stretch="Fill"
                                        CornerRadius="2"/>
    </Panel>
</UserControl>

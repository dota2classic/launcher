<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:res="clr-namespace:d2c_launcher.Resources"
             x:Class="d2c_launcher.Views.Components.Settings.VideoSettingsView"
             x:DataType="vm:GameSettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0" Margin="0,12,12,12">

            <!-- Fullscreen -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.FullscreenMode}" Classes="setting-label"/>
                    <TextBlock Text="{x:Static res:Strings.LaunchFullscreenDescription}" Classes="setting-desc"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding Fullscreen}"
                              VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Borderless window -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.BorderlessMode}" Classes="setting-label"/>
                    <TextBlock Text="{x:Static res:Strings.LaunchBorderlessDescription}" Classes="setting-desc"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding NoWindowBorder}"
                              VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Resolution -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.Resolution}" Classes="setting-label"/>
                    <TextBlock Text="{x:Static res:Strings.ScreenResolutionGame}" Classes="setting-desc"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <ComboBox Width="80"
                              ItemsSource="{Binding AvailableAspectRatios}"
                              SelectedIndex="{Binding SelectedAspectRatioIndex}"/>
                    <ComboBox Width="140"
                              ItemsSource="{Binding AvailableResolutions}"
                              SelectedItem="{Binding SelectedResolution}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ResolutionItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.Monitor}"
                                               IsVisible="{Binding IsNative}"
                                               Foreground="#66FFFFFF"
                                               FontSize="11"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>

</UserControl>

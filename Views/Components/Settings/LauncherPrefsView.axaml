<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:res="clr-namespace:d2c_launcher.Resources"
             x:Class="d2c_launcher.Views.Components.Settings.LauncherPrefsView"
             x:DataType="vm:LauncherPrefsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0" Margin="0,12,12,12">

            <!-- ═══ Game directory ═══ -->
            <TextBlock Text="{x:Static res:Strings.GameDirectory}" Classes="section-label" Margin="0,0,0,8"/>

            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="0,0,0,8">
                <Border Grid.Column="0" Background="#0c0e12" BorderBrush="#2d3842" BorderThickness="1"
                        Padding="6,5" VerticalAlignment="Stretch">
                    <TextBlock Text="📁" FontSize="{DynamicResource FontSizeLG}" VerticalAlignment="Center" Opacity="0.7"/>
                </Border>
                <Border Grid.Column="1" Background="#0c0e12" BorderBrush="#2d3842" BorderThickness="1"
                        Padding="8,5">
                    <TextBlock Text="{Binding GameDirectory}"
                               Foreground="#c0c4c8" FontSize="{DynamicResource FontSizeBase}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                </Border>
                <Button Grid.Column="2" Classes="dir-btn" Click="OnSelectDirectoryClicked"
                        Content="{x:Static res:Strings.Change}"/>
            </Grid>

            <TextBlock Text="{Binding FolderSizeText}"
                       Classes="setting-desc"
                       HorizontalAlignment="Right"
                       Margin="0,0,0,16"
                       IsVisible="{Binding FolderSizeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- ═══ Launch parameters ═══ -->

            <!-- Language -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.GameLanguage}" Classes="setting-label"/>
                    <TextBlock Text="{x:Static res:Strings.GameLanguageDescription}" Classes="setting-desc"/>
                </StackPanel>
                <ComboBox Grid.Column="1" Width="140"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          VerticalAlignment="Center"/>
            </Grid>

            <!-- Skip intro -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.SkipIntro}" Classes="setting-label"/>
                    <TextBlock Text="{x:Static res:Strings.SkipIntroDescription}" Classes="setting-desc"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding NoVid}"
                              VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- ═══ Launcher settings ═══ -->

            <!-- UI Scale -->
            <StackPanel Margin="0,0,0,16" Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="3">
                        <TextBlock Text="{x:Static res:Strings.UiScale}" Classes="setting-label"/>
                        <TextBlock Text="{x:Static res:Strings.UiScaleDescription}" Classes="setting-desc"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding UiScale}"
                               Classes="setting-label"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Width="24"
                               Margin="0,0,6,0"
                               TextAlignment="Center"/>
                </Grid>
                <Slider Minimum="0" Maximum="4"
                        Value="{Binding UiScale}"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"/>
            </StackPanel>

            <!-- Custom launch args -->
            <StackPanel Margin="0,0,0,16" Spacing="6">
                <TextBlock Text="{x:Static res:Strings.LaunchParameters}" Classes="setting-label"/>
                <TextBlock Text="{x:Static res:Strings.ExtraArgsHint}" Classes="setting-desc"/>
                <TextBox Text="{Binding ExtraArgs, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
            </StackPanel>

            <!-- Auto-update -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.AutoUpdateLauncher}" Classes="setting-label"/>
                    <TextBlock Text="{x:Static res:Strings.InstallUpdatesOnStartup}" Classes="setting-desc"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoUpdate}"
                              VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Close to tray -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.CloseToTray}" Classes="setting-label"/>
                    <TextBlock Text="{x:Static res:Strings.CloseToTrayDescription}" Classes="setting-desc"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding CloseToTray}"
                              VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Auto-connect to game -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.AutoConnectToServer}" Classes="setting-label"/>
                    <TextBlock Text="{x:Static res:Strings.AutoConnectDescription}" Classes="setting-desc"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoConnectToGame}"
                              VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Defender exclusion -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.DefenderExclusionTitle}" Classes="setting-label"/>
                    <TextBlock Text="{x:Static res:Strings.DefenderExclusionAdded}" Classes="setting-desc"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding DefenderExclusionEnabled}"
                              VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>

</UserControl>

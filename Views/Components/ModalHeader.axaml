<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="d2c_launcher.Views.Components.ModalHeader"
             x:Name="Root">

    <Border Background="#0c0f13" BorderBrush="#222830" BorderThickness="0,0,0,1" Height="48">
        <Grid ColumnDefinitions="*,Auto" Margin="18,0">
            <TextBlock Text="{Binding Title, ElementName=Root}"
                       FontSize="{DynamicResource FontSizeBase}" FontWeight="Bold" LetterSpacing="3"
                       Foreground="#d9dde0" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Click="OnCloseClicked"
                    Background="Transparent" BorderThickness="0"
                    Padding="4,0" Cursor="Hand" VerticalAlignment="Center">
                <TextBlock Text="✕" FontSize="{DynamicResource FontSizeLG}" Foreground="#606870" VerticalAlignment="Center"/>
            </Button>
        </Grid>
    </Border>

</UserControl>

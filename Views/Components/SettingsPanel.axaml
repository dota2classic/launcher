<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             x:Class="d2c_launcher.Views.Components.SettingsPanel"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.section-title">
            <Setter Property="Foreground" Value="#D9D9D9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- TabControl: transparent, no outer border -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Remove separator line and content area border from TabControl template -->
        <Style Selector="TabControl /template/ Border">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Flat underline tab item -->
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="#707070"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent"
                            BorderThickness="0,0,0,2"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Name="PART_HeaderPresenter"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
        </Style>

        <Style Selector="TabItem:pointerover">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>

        <Style Selector="TabItem:selected:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Width="500">
        <!-- Header -->
        <Border Background="#0A0B0D" Padding="18,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Настройки"
                           FontSize="16" FontWeight="SemiBold" Foreground="#D9D9D9"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Click="OnCloseClicked"
                        Background="Transparent" BorderThickness="0"
                        Padding="2,0" Cursor="Hand" VerticalAlignment="Center">
                    <TextBlock Text="✕" FontSize="16" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <StackPanel Spacing="12" Margin="18,12,18,18">
        <!-- ═══ Game directory (always visible above tabs) ═══ -->
        <StackPanel Spacing="4">
            <TextBlock Text="Директория игры:" Classes="section-title"/>
            <TextBlock x:Name="GameDirectoryText" Text="Не указано"
                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
            <Button Content="Изменить директорию" Click="OnSelectDirectoryClicked"/>
        </StackPanel>

        <TabControl MinHeight="260">
            <!-- ═══ Tab 1: Visual ═══ -->
            <TabItem Header="Визуальные">
                <StackPanel Spacing="16" Margin="0,12,0,0">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10">
                        <TextBlock Text="Язык игры" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" MinWidth="120"
                                  ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}"/>

                        <TextBlock Grid.Row="1" Text="Пропускать интро" VerticalAlignment="Center"/>
                        <ToggleSwitch Grid.Row="1" Grid.Column="1"
                                      IsChecked="{Binding NoVid}"
                                      OnContent="" OffContent=""
                                      HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- ═══ Tab 2: Gameplay ═══ -->
            <TabItem Header="Геймплей">
                <StackPanel Spacing="16" Margin="0,12,0,0">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                        <TextBlock Text="Автоатака" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" MinWidth="180"
                                  ItemsSource="{Binding AutoAttackOptions}"
                                  SelectedIndex="{Binding AutoAttackSelectedIndex}"/>

                        <TextBlock Grid.Row="1" Text="Атака правой кнопкой" VerticalAlignment="Center"/>
                        <ToggleSwitch Grid.Row="1" Grid.Column="1"
                                      IsChecked="{Binding ForceRightClickAttack}"
                                      OnContent="" OffContent=""
                                      HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="2" Text="Запретить зум камеры" VerticalAlignment="Center"/>
                        <ToggleSwitch Grid.Row="2" Grid.Column="1"
                                      IsChecked="{Binding DisableCameraZoom}"
                                      OnContent="" OffContent=""
                                      HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="3" Text="Автоповтор правой кнопки" VerticalAlignment="Center"/>
                        <ToggleSwitch Grid.Row="3" Grid.Column="1"
                                      IsChecked="{Binding RightMouseAutoRepeat}"
                                      OnContent="" OffContent=""
                                      HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="4" Text="Камера на героя при спавне" VerticalAlignment="Center"/>
                        <ToggleSwitch Grid.Row="4" Grid.Column="1"
                                      IsChecked="{Binding ResetCameraOnSpawn}"
                                      OnContent="" OffContent=""
                                      HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </TabItem>
        </TabControl>

        </StackPanel><!-- /inner content -->
    </StackPanel><!-- /root -->

</UserControl>

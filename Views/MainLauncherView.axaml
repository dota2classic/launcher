<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:d2c_launcher.ViewModels"
            xmlns:m="using:d2c_launcher.Models"
            xmlns:util="using:d2c_launcher.Util"
            xmlns:components="using:d2c_launcher.Views.Components"
            xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
            xmlns:res="clr-namespace:d2c_launcher.Resources"
            xmlns:l="clr-namespace:d2c_launcher.Util"
            x:Class="d2c_launcher.Views.MainLauncherView"
            x:DataType="vm:MainLauncherViewModel">
   <UserControl.Background>
       <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
           <GradientStop Color="#0c0c0c" Offset="0"/>
           <GradientStop Color="#1c2024" Offset="0.55"/>
           <GradientStop Color="#0c0c0c" Offset="1"/>
       </LinearGradientBrush>
   </UserControl.Background>
   <Grid>
           <Grid RowDefinitions="Auto,*,Auto">
               <components:LauncherHeader x:Name="LauncherHeaderControl" Grid.Row="0" DataContext="{Binding}"/>

               <!-- PLAY tab content -->
               <Grid Grid.Row="1" Margin="20,8,20,10" ColumnDefinitions="*,360"
                     IsVisible="{Binding IsPlayTabActive}">
                   <components:ChatPanel Grid.Column="0" Margin="0,0,16,0"
                                         DataContext="{Binding Chat}"/>
                   <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
                       <components:PartyPanel Grid.Row="0"
                                              DataContext="{Binding Party}"
                                              InviteClicked="OnInvitePlayerClicked"/>
                       <components:GameSearchPanel x:Name="GameSearchPanelControl" Grid.Row="1" DataContext="{Binding Queue}"/>
                       <StackPanel Grid.Row="2" Spacing="6" Margin="0,12,0,0">
                           <Grid ColumnDefinitions="*,Auto">
                               <components:QueueButton Grid.Column="0" DataContext="{Binding Queue}"
                                                       SearchClicked="OnSearchGameClicked"/>
                               <Button Grid.Column="1"
                                       IsVisible="{Binding CanAbandonGame}"
                                       Command="{Binding RequestAbandonGameCommand}"
                                       Width="52" Height="{Binding Queue.QueueButtonHeight}" Padding="0"
                                       Margin="6,0,0,0"
                                       Background="#1a0f0f" BorderBrush="{StaticResource BrushRed}" BorderThickness="1"
                                       CornerRadius="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                   <Button.Styles>
                                       <Style Selector="Button /template/ ContentPresenter">
                                           <Setter Property="Background" Value="#1a0f0f"/>
                                           <Setter Property="BorderBrush" Value="{StaticResource BrushRed}"/>
                                       </Style>
                                       <Style Selector="Button:pointerover /template/ ContentPresenter">
                                           <Setter Property="Background" Value="#2a1515"/>
                                           <Setter Property="BorderBrush" Value="{StaticResource BrushRed}"/>
                                       </Style>
                                   </Button.Styles>
                                   <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                             Foreground="{StaticResource BrushRed}" Width="16" Height="16"
                                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                               </Button>
                           </Grid>
                       </StackPanel>
                   </Grid>
               </Grid>

               <!-- LIVE tab content -->
              <Grid Grid.Row="1" Margin="20,8,20,10"
                    IsVisible="{Binding IsLiveTabActive}">
                  <components:LivePanel DataContext="{Binding Live}"/>
              </Grid>

              <!-- STREAMS tab content -->
              <Grid Grid.Row="1" Margin="20,8,20,10"
                    IsVisible="{Binding IsStreamsTabActive}">
                  <components:StreamsPanel DataContext="{Binding Streams}"/>
              </Grid>

              <!-- PROFILE tab content -->
               <Grid Grid.Row="1" Margin="20,8,20,10"
                     IsVisible="{Binding IsProfileTabActive}">
                   <components:ProfilePanel DataContext="{Binding Profile}"/>
               </Grid>

               <Grid Grid.Row="2" Margin="20,0,20,20"/>
           </Grid>

           <!-- Settings modal -->
           <components:ModalOverlay IsOpen="{Binding IsSettingsOpen}" ZIndex="100"
                                    Title="{x:Static res:Strings.Settings}"
                                    CloseCommand="{Binding CloseSettingsRelayCommand}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
               <components:ModalOverlay.ModalContent>
                   <components:SettingsPanel x:Name="SettingsPanelControl"
                                             DataContext="{Binding Settings}"
                                             Width="500"
                                             Height="500"/>
               </components:ModalOverlay.ModalContent>
           </components:ModalOverlay>

           <!-- Room ready-check modal -->
           <components:AcceptGameModal DataContext="{Binding Room}"/>

           <!-- Accept timeout modal -->
           <Panel IsVisible="{Binding Room.IsTimeoutModalOpen}" ZIndex="210"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#90000000">
               <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                       Padding="28,24" CornerRadius="0"
                       Background="#121315" BorderBrush="#2d3842" BorderThickness="1"
                       BoxShadow="0 12 28 0 #80000000">
                   <StackPanel Spacing="20">
                       <TextBlock Text="{l:T 'room.acceptTimeout'}" FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold"
                                  HorizontalAlignment="Center" Foreground="#D9D9D9"/>
                       <Button Classes="PrimaryButton" HorizontalAlignment="Center"
                               Content="{l:T 'room.acceptTimeoutClose'}" Command="{Binding Room.CloseTimeoutModalCommand}"
                               Padding="28,10" CornerRadius="0"/>
                   </StackPanel>
               </Border>
           </Panel>

           <!-- Abandon game confirmation overlay -->
           <Panel IsVisible="{Binding IsAbandonConfirmOpen}" ZIndex="210"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#90000000">
               <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                       Padding="28,24" CornerRadius="0"
                       Background="#121315" BorderBrush="#2d3842" BorderThickness="1"
                       BoxShadow="0 12 28 0 #80000000">
                   <StackPanel Spacing="20">
                       <TextBlock Text="{x:Static res:Strings.AbandonGameTitle}" FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold"
                                  HorizontalAlignment="Center" Foreground="#D9D9D9"/>
                       <TextBlock Text="{x:Static res:Strings.AbandonConfirmText}"
                                  HorizontalAlignment="Center" TextAlignment="Center"
                                  Foreground="#AAAAAA" FontSize="{DynamicResource FontSizeMD}"/>
                       <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                           <Button Classes="DangerButton"
                                   Content="{x:Static res:Strings.Leave}" Command="{Binding ConfirmAbandonGameCommand}"
                                   Padding="28,10" CornerRadius="0"/>
                           <Button Classes="PrimaryButton"
                                   Content="{x:Static res:Strings.Cancel}" Command="{Binding CancelAbandonGameCommand}"
                                   Padding="28,10" CornerRadius="0"/>
                       </StackPanel>
                   </StackPanel>
               </Border>
           </Panel>

           <!-- Floating party invite notifications (top-right) -->
           <components:NotificationArea DataContext="{Binding NotificationArea}"
                                        ZIndex="150"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,12,20,0"/>

           <!-- Invite player overlay -->
           <components:ModalOverlay IsOpen="{Binding Party.IsInviteModalOpen}" ZIndex="100"
                                    Title="{x:Static res:Strings.SelectPlayer}"
                                    CloseCommand="{Binding Party.CloseInviteModalCommand}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
               <components:ModalOverlay.ModalContent>
                   <StackPanel Spacing="12" Margin="18,12,18,18">
                       <TextBox Text="{Binding Party.InviteSearchText}" Watermark="{x:Static res:Strings.PlayerNickname}"/>
                       <Border Background="#0c0c0c" BorderBrush="#2d3842" BorderThickness="1" Height="300">
                           <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                               <ItemsControl ItemsSource="{Binding Party.InviteCandidates}">
                                   <ItemsControl.ItemTemplate>
                                       <DataTemplate x:DataType="m:InviteCandidateView">
                                           <Button Click="OnInviteCandidateClicked"
                                                   Background="Transparent" BorderThickness="0" Padding="0"
                                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                               <Border Padding="8" BorderBrush="#242c34" BorderThickness="0,0,0,1">
                                                   <components:PlayerPreviewControl/>
                                               </Border>
                                           </Button>
                                       </DataTemplate>
                                   </ItemsControl.ItemTemplate>
                               </ItemsControl>
                           </ScrollViewer>
                       </Border>
                   </StackPanel>
               </components:ModalOverlay.ModalContent>
           </components:ModalOverlay>

           <!-- Intro overlay -->
           <Panel IsVisible="{Binding Intro.IsOpen}" ZIndex="200"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
               <components:SpotlightOverlay x:Name="IntroSpotlight"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
               <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                       Width="420" Padding="0" CornerRadius="0"
                       Background="#121315" BorderBrush="#2d3842" BorderThickness="1"
                       BoxShadow="0 12 28 0 #80000000">
                   <StackPanel>
                       <!-- Header -->
                       <Border Background="#0A0B0D" Padding="18,14">
                           <StackPanel>
                               <TextBlock Text="{x:Static res:Strings.WelcomeTitle}"
                                          FontSize="{DynamicResource FontSize2XL}" FontWeight="Bold" Foreground="#D9D9D9"/>
                               <TextBlock Foreground="#4DA9F3" FontSize="{DynamicResource FontSizeBase}" Margin="0,4,0,0">
                                   <TextBlock.Text>
                                       <MultiBinding StringFormat="Шаг {0} из {1}">
                                           <Binding Path="Intro.Step"/>
                                           <Binding Path="Intro.StepCount"/>
                                       </MultiBinding>
                                   </TextBlock.Text>
                               </TextBlock>
                           </StackPanel>
                       </Border>

                       <!-- Step content -->
                       <StackPanel Margin="18,16,18,20" Spacing="12" MinHeight="120">
                           <!-- Step 1: Launch button -->
                           <StackPanel IsVisible="{Binding Intro.Step, Converter={x:Static util:IntroStepConverter.Instance}, ConverterParameter=1}" Spacing="8">
                               <TextBlock Text="▶  Как запустить игру" FontSize="{DynamicResource FontSizeLG}" FontWeight="SemiBold" Foreground="#4DA9F3"/>
                               <TextBlock TextWrapping="Wrap" Foreground="#C0C0C0" FontSize="{DynamicResource FontSizeMD}">
                                   Эта кнопка в правом верхнем углу запускает старую Dota 2. Можешь запустить, посмотреть на игровой клиент и выставить настройки.
                               </TextBlock>
                           </StackPanel>
                           <!-- Step 2: Settings -->
                           <StackPanel IsVisible="{Binding Intro.Step, Converter={x:Static util:IntroStepConverter.Instance}, ConverterParameter=2}" Spacing="8">
                               <TextBlock Text="⚙  Настройки" FontSize="{DynamicResource FontSizeLG}" FontWeight="SemiBold" Foreground="#4DA9F3"/>
                               <TextBlock TextWrapping="Wrap" Foreground="#C0C0C0" FontSize="{DynamicResource FontSizeMD}">
                                   Значок шестерёнки рядом с кнопкой запуска открывает панель настроек. Там самые нужные параметры - полный экран, разрешение, язык и другие.
                               </TextBlock>
                           </StackPanel>
                           <!-- Step 3: Matchmaking modes -->
                           <StackPanel IsVisible="{Binding Intro.Step, Converter={x:Static util:IntroStepConverter.Instance}, ConverterParameter=3}" Spacing="8">
                               <TextBlock Text="🎮  Режимы и поиск игры" FontSize="{DynamicResource FontSizeLG}" FontWeight="SemiBold" Foreground="#4DA9F3"/>
                               <TextBlock TextWrapping="Wrap" Foreground="#C0C0C0" FontSize="{DynamicResource FontSizeMD}">
                                   В правой части экрана выберите один или несколько режимов игры, затем нажмите «Играть». Когда матч будет найден — подтвердите готовность прямо в лаунчере. Искать игру через игровой клиент - НЕ НУЖНО.
                               </TextBlock>
                           </StackPanel>
                           <!-- Step 4: Bot requirement to unlock 5x5 -->
                           <StackPanel IsVisible="{Binding Intro.Step, Converter={x:Static util:IntroStepConverter.Instance}, ConverterParameter=4}" Spacing="8">
                               <TextBlock Text="🤖  Начните с ботов" FontSize="{DynamicResource FontSizeLG}" FontWeight="SemiBold" Foreground="#4DA9F3"/>
                               <TextBlock TextWrapping="Wrap" Foreground="#C0C0C0" FontSize="{DynamicResource FontSizeMD}">
                                   Режимы 5×5 с живыми игроками заблокированы для новых аккаунтов. Сыграйте несколько игр против ботов — это нужно, чтобы убедиться, что вы знаете основы игры. После этого все режимы откроются автоматически.
                               </TextBlock>
                           </StackPanel>
                       </StackPanel>

                       <!-- Footer buttons -->
                       <Border Background="#0A0B0D" Padding="18,12">
                           <Button Classes="PrimaryButton"
                                   HorizontalAlignment="Right"
                                   Command="{Binding Intro.NextStepCommand}"
                                   Padding="22,9" FontSize="{DynamicResource FontSizeLG}"
                                   CornerRadius="0" Cursor="Hand">
                               <TextBlock>
                                   <TextBlock.Text>
                                       <Binding Path="Intro.Step"
                                                Converter="{x:Static util:IntroNextButtonTextConverter.Instance}"/>
                                   </TextBlock.Text>
                               </TextBlock>
                           </Button>
                       </Border>
                   </StackPanel>
               </Border>
           </Panel>

   </Grid>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:d2c_launcher.ViewModels"
            xmlns:m="using:d2c_launcher.Models"
            xmlns:util="using:d2c_launcher.Util"
            xmlns:components="using:d2c_launcher.Views.Components"
            xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
            x:Class="d2c_launcher.Views.MainLauncherView"
            x:DataType="vm:MainLauncherViewModel">
   <UserControl.Background>
       <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
           <GradientStop Color="#0c0c0c" Offset="0"/>
           <GradientStop Color="#1c2024" Offset="0.55"/>
           <GradientStop Color="#0c0c0c" Offset="1"/>
       </LinearGradientBrush>
   </UserControl.Background>
   <UserControl.Styles>
   </UserControl.Styles>

   <Grid>
           <Grid RowDefinitions="Auto,*,Auto">
               <components:LauncherHeader x:Name="LauncherHeaderControl" Grid.Row="0" DataContext="{Binding}"/>

               <Grid Grid.Row="1" Margin="20,8,20,10" ColumnDefinitions="*,360">
                   <!-- Chat -->
                   <components:ChatPanel Grid.Column="0" Margin="0,0,16,0"
                                         DataContext="{Binding Chat}"/>

                   <!-- Right panel: party + modes + queue button -->
                   <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
                       <components:PartyPanel Grid.Row="0"
                                              DataContext="{Binding Party}"
                                              InviteClicked="OnInvitePlayerClicked"/>

                       <components:GameSearchPanel x:Name="GameSearchPanelControl" Grid.Row="1" DataContext="{Binding Queue}"/>

                       <!-- Server URL + queue button -->
                       <StackPanel Grid.Row="2" Spacing="6" Margin="0,12,0,0">
                           <Border IsVisible="{Binding Launch.HasServerUrl}"
                                   Background="#121315" BorderBrush="#243446" BorderThickness="1"
                                   CornerRadius="0" Padding="10,6">
                               <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                   <TextBlock Text="Сервер:" Foreground="#4DA9F3" FontSize="12" VerticalAlignment="Center"/>
                                   <TextBlock Text="{Binding Launch.ServerUrl}" Foreground="#D9D9D9" FontSize="12"
                                              FontFamily="Monospace" VerticalAlignment="Center"/>
                               </StackPanel>
                           </Border>
                           <components:QueueButton DataContext="{Binding Queue}"
                                                   SearchClicked="OnSearchGameClicked"/>
                       </StackPanel>
                   </Grid>
               </Grid>

               <Grid Grid.Row="2" Margin="20,0,20,20"/>
           </Grid>

           <!-- Room ready-check modal -->
           <components:AcceptGameModal DataContext="{Binding Room}"/>

           <!-- Floating party invite notifications (top-right) -->
           <components:NotificationArea DataContext="{Binding NotificationArea}"
                                        ZIndex="150"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,12,20,0"/>

           <!-- Invite player overlay -->
           <Panel IsVisible="{Binding Party.IsInviteModalOpen}" ZIndex="100"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#80000000"
                  PointerPressed="OnInviteOverlayBackdropPressed">
               <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                       PointerPressed="OnInviteModalPointerPressed"
                       Padding="0" CornerRadius="0"
                       Background="#121315" BorderBrush="#2d3842" BorderThickness="1"
                       BoxShadow="0 12 28 0 #80000000" Width="300">
                   <StackPanel>
                       <!-- Header -->
                       <Border Background="#0A0B0D" Padding="18,10">
                           <Grid ColumnDefinitions="*,Auto">
                               <TextBlock Text="Выбрать игрока"
                                          FontSize="16" FontWeight="SemiBold" Foreground="#D9D9D9"
                                          VerticalAlignment="Center"/>
                               <Button Grid.Column="1" Click="OnCloseInviteModal"
                                       Background="Transparent" BorderThickness="0"
                                       Padding="2,0" Cursor="Hand" VerticalAlignment="Center">
                                   <TextBlock Text="✕" FontSize="16" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                               </Button>
                           </Grid>
                       </Border>
                       <StackPanel Spacing="12" Margin="18,12,18,18">
                           <TextBox Text="{Binding Party.InviteSearchText}" Watermark="Никнейм игрока"/>
                           <Border Background="#0c0c0c" BorderBrush="#2d3842" BorderThickness="1" Height="300">
                               <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                   <ItemsControl ItemsSource="{Binding Party.InviteCandidates}">
                                       <ItemsControl.ItemTemplate>
                                           <DataTemplate x:DataType="m:InviteCandidateView">
                                               <Button Click="OnInviteCandidateClicked"
                                                       Background="Transparent" BorderThickness="0" Padding="0"
                                                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                                   <Border Padding="8" BorderBrush="#242c34" BorderThickness="0,0,0,1">
                                                       <components:PlayerPreviewControl/>
                                                   </Border>
                                               </Button>
                                           </DataTemplate>
                                       </ItemsControl.ItemTemplate>
                                   </ItemsControl>
                               </ScrollViewer>
                           </Border>
                       </StackPanel>
                   </StackPanel>
               </Border>
           </Panel>

           <!-- Intro overlay -->
           <Panel IsVisible="{Binding IsIntroOpen}" ZIndex="200"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
               <components:SpotlightOverlay x:Name="IntroSpotlight"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
               <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                       Width="420" Padding="0" CornerRadius="0"
                       Background="#121315" BorderBrush="#2d3842" BorderThickness="1"
                       BoxShadow="0 12 28 0 #80000000">
                   <StackPanel>
                       <!-- Header -->
                       <Border Background="#0A0B0D" Padding="18,14">
                           <Grid ColumnDefinitions="*,Auto">
                               <StackPanel>
                                   <TextBlock Text="Добро пожаловать в D2C Launcher"
                                              FontSize="17" FontWeight="Bold" Foreground="#D9D9D9"/>
                                   <TextBlock Foreground="#4DA9F3" FontSize="12" Margin="0,4,0,0">
                                       <TextBlock.Text>
                                           <MultiBinding StringFormat="Шаг {0} из {1}">
                                               <Binding Path="IntroStep"/>
                                               <Binding Path="IntroStepCount"/>
                                           </MultiBinding>
                                       </TextBlock.Text>
                                   </TextBlock>
                               </StackPanel>
                               <Button Grid.Column="1" Command="{Binding CloseIntroCommand}"
                                       Background="Transparent" BorderThickness="0"
                                       Padding="2,0" Cursor="Hand" VerticalAlignment="Top">
                                   <TextBlock Text="✕" FontSize="16" Foreground="#AAAAAA"/>
                               </Button>
                           </Grid>
                       </Border>

                       <!-- Step content -->
                       <StackPanel Margin="18,16,18,20" Spacing="12" MinHeight="120">
                           <!-- Step 1: Play button -->
                           <StackPanel IsVisible="{Binding IntroStep, Converter={x:Static util:IntroStepConverter.Instance}, ConverterParameter=1}" Spacing="8">
                               <TextBlock Text="▶  Кнопка запуска игры" FontSize="15" FontWeight="SemiBold" Foreground="#4DA9F3"/>
                               <TextBlock TextWrapping="Wrap" Foreground="#C0C0C0" FontSize="13">
                                   В правом верхнем углу находится кнопка запуска. Нажмите её, чтобы запустить Dotaclassic. Если игра уже запущена и найден сервер — кнопка изменится на «Подключиться».
                               </TextBlock>
                           </StackPanel>
                           <!-- Step 2: Settings -->
                           <StackPanel IsVisible="{Binding IntroStep, Converter={x:Static util:IntroStepConverter.Instance}, ConverterParameter=2}" Spacing="8">
                               <TextBlock Text="⚙  Настройки" FontSize="15" FontWeight="SemiBold" Foreground="#4DA9F3"/>
                               <TextBlock TextWrapping="Wrap" Foreground="#C0C0C0" FontSize="13">
                                   Значок шестерёнки рядом с кнопкой запуска открывает панель настроек. Там можно настроить графику, геймплей (чувствительность, быстрый каст), язык, а также параметры загрузки.
                               </TextBlock>
                           </StackPanel>
                           <!-- Step 3: Matchmaking modes -->
                           <StackPanel IsVisible="{Binding IntroStep, Converter={x:Static util:IntroStepConverter.Instance}, ConverterParameter=3}" Spacing="8">
                               <TextBlock Text="🎮  Режимы и поиск игры" FontSize="15" FontWeight="SemiBold" Foreground="#4DA9F3"/>
                               <TextBlock TextWrapping="Wrap" Foreground="#C0C0C0" FontSize="13">
                                   В правой части экрана выберите один или несколько режимов игры, затем нажмите «Найти игру». Когда матч будет найден — подтвердите готовность прямо в лаунчере.
                               </TextBlock>
                           </StackPanel>
                           <!-- Step 4: Bots suggestion -->
                           <StackPanel IsVisible="{Binding IntroStep, Converter={x:Static util:IntroStepConverter.Instance}, ConverterParameter=4}" Spacing="8">
                               <TextBlock Text="🤖  Совет: сыграйте против ботов" FontSize="15" FontWeight="SemiBold" Foreground="#4DA9F3"/>
                               <TextBlock TextWrapping="Wrap" Foreground="#C0C0C0" FontSize="13">
                                   Если вы новичок или хотите потренироваться — выберите режим «Боты» перед поиском. Это отличный способ освоиться в игре без давления соперников.
                               </TextBlock>
                           </StackPanel>
                       </StackPanel>

                       <!-- Footer buttons -->
                       <Border Background="#0A0B0D" Padding="18,12">
                           <Grid ColumnDefinitions="*,Auto,Auto">
                               <Button Grid.Column="0" Command="{Binding CloseIntroCommand}"
                                       Background="Transparent" BorderThickness="0"
                                       Padding="0" Cursor="Hand" VerticalAlignment="Center"
                                       HorizontalAlignment="Left">
                                   <TextBlock Text="Пропустить" Foreground="#666" FontSize="12"/>
                               </Button>
                               <Button Grid.Column="2" Command="{Binding NextIntroStepCommand}"
                                       Padding="22,9" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" BorderThickness="0" CornerRadius="0" Cursor="Hand">
                                   <Button.Background>
                                       <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                           <GradientStop Color="#1a5aaa" Offset="0"/>
                                           <GradientStop Color="#3a90d6" Offset="1"/>
                                       </LinearGradientBrush>
                                   </Button.Background>
                                   <TextBlock>
                                       <TextBlock.Text>
                                           <Binding Path="IntroStep"
                                                    Converter="{x:Static util:IntroNextButtonTextConverter.Instance}"/>
                                       </TextBlock.Text>
                                   </TextBlock>
                               </Button>
                           </Grid>
                       </Border>
                   </StackPanel>
               </Border>
           </Panel>

           <!-- Settings overlay -->
           <Panel x:Name="SettingsOverlay" IsVisible="{Binding IsSettingsOpen}" ZIndex="100"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#80000000"
                  PointerPressed="OnSettingsOverlayBackdropPressed">
               <Border x:Name="SettingsBorder" HorizontalAlignment="Center" VerticalAlignment="Center"
                       PointerPressed="OnSettingsPanelPointerPressed"
                       Padding="0" CornerRadius="0"
                       Background="#121315" BorderBrush="#2d3842" BorderThickness="1"
                       BoxShadow="0 12 28 0 #80000000">
                   <components:SettingsPanel x:Name="SettingsPanelControl"
                                             DataContext="{Binding Settings}"/>
               </Border>
           </Panel>
   </Grid>

</UserControl>

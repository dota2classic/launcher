<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:d2c_launcher.ViewModels"
        xmlns:v="using:d2c_launcher.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="d2c_launcher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/icon.ico"
        Title="{Binding WindowTitle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1a6b30" IsVisible="{Binding UpdateAvailable}" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Доступна новая версия, готова к установке."
                               Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ReleaseNotes}"
                               IsVisible="{Binding ReleaseNotes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="#ccffffff" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"
                        Content="Перезапустить и обновить"
                        Command="{Binding ApplyUpdateCommand}"/>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1" Content="{Binding CurrentContentViewModel}"/>
    </Grid>

</Window>

<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="d2c_launcher.App"
             xmlns:local="using:d2c_launcher"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:v="using:d2c_launcher.Views"
             xmlns:dialogHost="using:DialogHostAvalonia"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <FontFamily x:Key="TrajanPro3">avares://d2c-launcher/Assets/Fonts#Trajan Pro 3</FontFamily>
        <FontFamily x:Key="NotoSans">avares://d2c-launcher/Assets/Fonts#Noto Sans</FontFamily>
        <x:Double x:Key="FontSizeXS">10</x:Double>
        <x:Double x:Key="FontSizeSM">11</x:Double>
        <x:Double x:Key="FontSizeBase">12</x:Double>
        <x:Double x:Key="FontSizeMD">13</x:Double>
        <x:Double x:Key="FontSizeLG">14</x:Double>
        <x:Double x:Key="FontSizeXL">16</x:Double>
        <x:Double x:Key="FontSize2XL">18</x:Double>
        <x:Double x:Key="FontSize3XL">22</x:Double>
        <x:Double x:Key="FontSize4XL">28</x:Double>
    </Application.Resources>

   <Application.DataTemplates>
        <DataTemplate DataType="vm:LoadingViewModel">
            <v:LoadingView/>
        </DataTemplate>
        <DataTemplate DataType="vm:LaunchSteamFirstViewModel">
            <v:LaunchSteamFirstView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SelectGameViewModel">
            <v:SelectGameView/>
        </DataTemplate>
        <DataTemplate DataType="vm:GameDownloadViewModel">
            <v:GameDownloadView/>
        </DataTemplate>
        <DataTemplate DataType="vm:MainLauncherViewModel">
            <v:MainLauncherView/>
        </DataTemplate>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/icon.ico" ToolTipText="D2C Launcher" Clicked="TrayOpen_Click">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Открыть" Click="TrayOpen_Click"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Выход" Click="TrayExit_Click"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Styles>
        <FluentTheme />
        <Style Selector=":is(TemplatedControl)">
            <Setter Property="FontFamily" Value="{StaticResource NotoSans}"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource NotoSans}"/>
            <Setter Property="Foreground" Value="#D9D9D9"/>
        </Style>
        <dialogHost:DialogHostStyles />
        <materialIcons:MaterialIconStyles/>
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#D9D9D9"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                        <Border x:Name="CheckMark"
                                Grid.Column="0"
                                Width="18" Height="18"
                                CornerRadius="4"
                                Background="#1c2024"
                                BorderBrush="#2d3842"
                                BorderThickness="1.5"
                                VerticalAlignment="Center">
                            <Path x:Name="CheckGlyph"
                                  Data="M 3 9 L 7 13 L 15 5"
                                  Stroke="#4DA9F3"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  IsVisible="{TemplateBinding IsChecked}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          Margin="8,0,0,0"
                                          Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="CheckBox:pointerover /template/ Border#CheckMark">
            <Setter Property="BorderBrush" Value="#4DA9F3"/>
            <Setter Property="Background" Value="#1c2a3a"/>
        </Style>
        <Style Selector="CheckBox:checked /template/ Border#CheckMark">
            <Setter Property="BorderBrush" Value="#4DA9F3"/>
            <Setter Property="Background" Value="#1c2024"/>
        </Style>

        <!-- ── TabControl: transparent, no outer border ── -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TabControl /template/ Border">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- ── TabItem: gold underline on selected ── -->
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="#505860"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent"
                            BorderThickness="0,0,0,2"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Name="PART_HeaderPresenter"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#C8A84B"/>
            <Setter Property="BorderBrush" Value="#C8A84B"/>
        </Style>
        <Style Selector="TabItem:pointerover">
            <Setter Property="Foreground" Value="#9a9ea4"/>
        </Style>
        <Style Selector="TabItem:selected:pointerover">
            <Setter Property="Foreground" Value="#C8A84B"/>
        </Style>

        <!-- ── SubTab: manual border-based tabs (e.g. ProfilePanel) ── -->
        <Style Selector="Border.SubTab">
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.SubTabActive">
            <Setter Property="BorderBrush" Value="#C8A84B"/>
        </Style>
        <Style Selector="TextBlock.SubTabText">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeXS}"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
            <Setter Property="Foreground" Value="#556070"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="TextBlock.SubTabTextActive">
            <Setter Property="Foreground" Value="#C8A84B"/>
        </Style>

        <!-- ── Reusable panel block styles ── -->
        <Style Selector="Border.Block">
            <Setter Property="Background" Value="#13171D"/>
            <Setter Property="BorderBrush" Value="#252E3A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.BlockHead">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#0A0C0F"/>
            <Setter Property="BorderBrush" Value="#252E3A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="14,0"/>
        </Style>
        <Style Selector="TextBlock.BlockTitle">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeXS}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Foreground" Value="#D9D9D9"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Application.Styles>
</Application>

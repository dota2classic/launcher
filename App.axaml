<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="d2c_launcher.App"
             xmlns:local="using:d2c_launcher"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:v="using:d2c_launcher.Views"
             xmlns:dialogHost="using:DialogHostAvalonia"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- ── Brand colors ── -->
        <Color x:Key="ColorGreen">#92a525</Color>
        <Color x:Key="ColorRed">#c23c2a</Color>
        <Color x:Key="ColorGrey">#979797</Color>
        <SolidColorBrush x:Key="BrushGreen" Color="{StaticResource ColorGreen}"/>
        <SolidColorBrush x:Key="BrushRed"   Color="{StaticResource ColorRed}"/>
        <SolidColorBrush x:Key="BrushGrey"  Color="{StaticResource ColorGrey}"/>

        <FontFamily x:Key="TrajanPro3">avares://d2c-launcher/Assets/Fonts#Trajan Pro 3</FontFamily>
        <FontFamily x:Key="NotoSans">avares://d2c-launcher/Assets/Fonts#Noto Sans</FontFamily>
        <x:Double x:Key="FontSize2XS">9</x:Double>
        <x:Double x:Key="FontSizeXS">10</x:Double>
        <x:Double x:Key="FontSizeSM">11</x:Double>
        <x:Double x:Key="FontSizeBase">12</x:Double>
        <x:Double x:Key="FontSizeMD">13</x:Double>
        <x:Double x:Key="FontSizeLG">14</x:Double>
        <x:Double x:Key="FontSizeXL">16</x:Double>
        <x:Double x:Key="FontSize2XL">18</x:Double>
        <x:Double x:Key="FontSize2XL5">20</x:Double>
        <x:Double x:Key="FontSize3XL">22</x:Double>
        <x:Double x:Key="FontSize4XL">28</x:Double>
    </Application.Resources>

   <Application.DataTemplates>
        <DataTemplate DataType="vm:LoadingViewModel">
            <v:LoadingView/>
        </DataTemplate>
        <DataTemplate DataType="vm:LaunchSteamFirstViewModel">
            <v:LaunchSteamFirstView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SelectGameViewModel">
            <v:SelectGameView/>
        </DataTemplate>
        <DataTemplate DataType="vm:GameDownloadViewModel">
            <v:GameDownloadView/>
        </DataTemplate>
        <DataTemplate DataType="vm:MainLauncherViewModel">
            <v:MainLauncherView/>
        </DataTemplate>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/icon.ico" ToolTipText="D2C Launcher" Clicked="TrayOpen_Click">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Открыть" Click="TrayOpen_Click"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Выход" Click="TrayExit_Click"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Styles>
        <FluentTheme />
        <Style Selector=":is(TemplatedControl)">
            <Setter Property="FontFamily" Value="{StaticResource NotoSans}"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource NotoSans}"/>
            <Setter Property="Foreground" Value="#D9D9D9"/>
        </Style>
        <dialogHost:DialogHostStyles />
        <materialIcons:MaterialIconStyles/>
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <!-- CheckBox: Dota-2 style — filled square indicator, no checkmark glyph -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#D9D9D9"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent" Padding="0,3">
                        <Grid ColumnDefinitions="18,*" VerticalAlignment="Center">
                            <Border x:Name="CheckMark"
                                    Grid.Column="0"
                                    Width="16" Height="16"
                                    CornerRadius="1"
                                    Background="Transparent"
                                    BorderBrush="#505860"
                                    BorderThickness="1.5"
                                    VerticalAlignment="Center"/>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="CheckBox:pointerover /template/ Border#CheckMark">
            <Setter Property="BorderBrush" Value="#3a90d6"/>
        </Style>
        <Style Selector="CheckBox:checked /template/ Border#CheckMark">
            <Setter Property="Background" Value="#c8e4ff"/>
            <Setter Property="BorderBrush" Value="#3a90d6"/>
            <Setter Property="BoxShadow" Value="0 0 6 1 #503a90d6"/>
        </Style>
        <Style Selector="CheckBox:checked:pointerover /template/ Border#CheckMark">
            <Setter Property="Background" Value="#d8ecff"/>
            <Setter Property="BoxShadow" Value="0 0 8 2 #603a90d6"/>
        </Style>
        <Style Selector="CheckBox:disabled">
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <!-- ── TabControl: transparent, no outer border ── -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TabControl /template/ Border">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- ── TabItem: gold underline on selected ── -->
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="#505860"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent"
                            BorderThickness="0,0,0,2"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Name="PART_HeaderPresenter"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#C8A84B"/>
            <Setter Property="BorderBrush" Value="#C8A84B"/>
        </Style>
        <Style Selector="TabItem:pointerover">
            <Setter Property="Foreground" Value="#9a9ea4"/>
        </Style>
        <Style Selector="TabItem:selected:pointerover">
            <Setter Property="Foreground" Value="#C8A84B"/>
        </Style>

        <!-- ── SubTab: manual border-based tabs (e.g. ProfilePanel) ── -->
        <Style Selector="Border.SubTab">
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.SubTabActive">
            <Setter Property="BorderBrush" Value="#C8A84B"/>
        </Style>
        <Style Selector="TextBlock.SubTabText">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeXS}"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
            <Setter Property="Foreground" Value="#556070"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="TextBlock.SubTabTextActive">
            <Setter Property="Foreground" Value="#C8A84B"/>
        </Style>

        <!-- ── Init screens (Loading, LaunchSteamFirst, SelectGame, GameDownload) ── -->
        <Style Selector="UserControl.InitScreen">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0c0c0c" Offset="0"/>
                        <GradientStop Color="#141820" Offset="0.35"/>
                        <GradientStop Color="#1c2024" Offset="0.5"/>
                        <GradientStop Color="#141820" Offset="0.65"/>
                        <GradientStop Color="#0c0c0c" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="TextBlock.InitScreenTitle">
            <Setter Property="FontFamily" Value="{StaticResource TrajanPro3}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize4XL}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#D9D9D9"/>
        </Style>
        <Style Selector="StackPanel.InitScreenContent">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Spacing" Value="16"/>
            <Setter Property="MaxWidth" Value="420"/>
            <Setter Property="Margin" Value="24,0"/>
        </Style>

        <!-- ── Toast notification shell ── -->
        <Style Selector="Border.ToastShell">
            <Setter Property="Background" Value="#1c2024"/>
            <Setter Property="BorderBrush" Value="#2d3842"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Width" Value="290"/>
            <Setter Property="MaxHeight" Value="500"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MaxHeight" Duration="0:0:0.2" Easing="CubicEaseIn"/>
                    <ThicknessTransition Property="Margin" Duration="0:0:0.2" Easing="CubicEaseIn"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.ToastShell.closing">
            <Setter Property="MaxHeight" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- ── Named button styles ── -->
        <!-- PrimaryButton: blue gradient, used for primary actions (Accept, Next, Cancel-Abandon) -->
        <Style Selector="Button.PrimaryButton">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1a5aaa" Offset="0"/>
                        <GradientStop Color="#3a90d6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.PrimaryButton:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.PrimaryButton:pointerover TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.PrimaryButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2a6aba" Offset="0"/>
                        <GradientStop Color="#4aa0e6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- DangerButton: dark bg + red border/text, used for destructive actions (Decline, Abandon) -->
        <Style Selector="Button.DangerButton">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource BrushRed}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <!-- Pin background + border via ContentPresenter — Fluent theme overrides button-level values there -->
        <Style Selector="Button.DangerButton /template/ ContentPresenter">
            <Setter Property="Background" Value="#1a0a08"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushRed}"/>
        </Style>
        <Style Selector="Button.DangerButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2c1412"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushRed}"/>
            <Setter Property="TextElement.Foreground" Value="{StaticResource BrushRed}"/>
        </Style>
        <Style Selector="Button.DangerButton:pointerover TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushRed}"/>
        </Style>
        <!-- IconButton: transparent small icon button with dark hover, used in chat toolbar -->
        <Style Selector="Button.IconButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#252c38"/>
        </Style>
        <!-- ToastDismissButton: small ✕ dismiss button used in all toast notifications -->
        <Style Selector="Button.ToastDismissButton">
            <Setter Property="Content" Value="✕"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#535252"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- ── Reusable panel block styles ── -->
        <Style Selector="Border.Block">
            <Setter Property="Background" Value="#13171D"/>
            <Setter Property="BorderBrush" Value="#252E3A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.BlockHead">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#0A0C0F"/>
            <Setter Property="BorderBrush" Value="#252E3A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="14,0"/>
        </Style>
        <Style Selector="TextBlock.BlockTitle">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeXS}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Foreground" Value="#D9D9D9"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Application.Styles>
</Application>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:d2c_launcher.ViewModels"
             xmlns:m="using:d2c_launcher.Models"
             xmlns:util="using:d2c_launcher.Util"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="d2c_launcher.Preview.InviteModalPreviewControl"
             x:DataType="vm:PartyViewModel"
             HorizontalAlignment="Center" VerticalAlignment="Center">


    <Border Background="#121315" BorderBrush="#2d3842" BorderThickness="1"
            Padding="0" BoxShadow="0 12 28 0 #80000000" Width="300">
        <StackPanel>

            <!-- Header -->
            <Border Background="#0A0B0D" Padding="18,10">
                <TextBlock Text="Выбрать игрока"
                           FontSize="16" FontWeight="SemiBold" Foreground="#D9D9D9"
                           VerticalAlignment="Center"/>
            </Border>

            <StackPanel Spacing="12" Margin="18,12,18,18">
            <!-- Search -->
            <TextBox Text="{Binding InviteSearchText}" Watermark="Никнейм игрока"/>

            <!-- Player list -->
            <Border Background="#0c0c0c" BorderBrush="#2d3842" BorderThickness="1" Height="300">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding InviteCandidates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:InviteCandidateView">
                                <Border Padding="8" BorderBrush="#242c34" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Grid Width="40" Height="40">
                                            <Panel Width="36" Height="36"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse Width="36" Height="36" Fill="#242c34"/>
                                                <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" FontSize="12"/>
                                                <Ellipse Width="36" Height="36">
                                                    <Ellipse.Fill>
                                                        <ImageBrush asyncImageLoader:ImageBrushLoader.Source="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Panel>
                                            <Ellipse Width="10" Height="10" Fill="#44D46F"
                                                     IsVisible="{Binding IsOnline}"
                                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                     Margin="0,0,2,2"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            </StackPanel><!-- /inner content -->
        </StackPanel>
    </Border>

</UserControl>
